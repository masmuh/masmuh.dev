---
import HeroSection from "./HeroSection.astro";
import AboutSection from "./AboutSection.astro";
import SkillsSection from "./SkillsSection.astro";
import ExperienceSection from "./ExperienceSection.astro";
import ProjectsSection from "./ProjectsSection.astro";
import ContactSection from "./ContactSection.astro";

interface Section {
  id: string;
  num: string;
  label: string;
}

const sections: Section[] = [
  { id: "hero", num: "00", label: "Home" },
  { id: "about", num: "01", label: "About" },
  { id: "skills", num: "02", label: "Skills" },
  { id: "experience", num: "03", label: "Experience" },
  { id: "projects", num: "04", label: "Projects" },
  { id: "contact", num: "05", label: "Contact" },
];
---

<div class="switcher-layout">
  <nav class="switcher-nav" aria-label="Section navigation">
    {sections.map((s) => (
      <button
        class="switcher-nav-item"
        class:list={{ active: s.id === "hero" }}
        data-switcher-target={sections.indexOf(s)}
        aria-label={`Switch to ${s.label} section`}
      >{s.num} {s.label}</button>
    ))}
  </nav>

  <div class="switcher-hint" id="switcherHint" aria-live="polite">
    <span class="hint-icon">⌨</span>
    <span>Use <kbd>←</kbd> <kbd>→</kbd> arrow keys or click tabs to navigate</span>
  </div>

  <div class="switcher-cards">
    <div class="switcher-card active" data-switcher-card="hero">
      <HeroSection />
    </div>
    <div class="switcher-card" data-switcher-card="about">
      <AboutSection />
    </div>
    <div class="switcher-card" data-switcher-card="skills">
      <SkillsSection />
    </div>
    <div class="switcher-card" data-switcher-card="experience">
      <ExperienceSection />
    </div>
    <div class="switcher-card" data-switcher-card="projects">
      <ProjectsSection />
    </div>
    <div class="switcher-card" data-switcher-card="contact">
      <ContactSection />
    </div>
  </div>
</div>

<style>
  .switcher-layout {
    position: relative;
    height: calc(100vh - 80px);
    margin-top: 80px;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .switcher-nav {
    display: flex;
    gap: 0;
    padding: 0 64px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    background: var(--bg);
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .switcher-nav::-webkit-scrollbar { display: none; }

  .switcher-nav-item {
    padding: 14px 20px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.3s;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .switcher-nav-item:hover {
    color: var(--cyan);
    border-bottom-color: rgba(0, 200, 255, 0.3);
  }

  .switcher-nav-item.active {
    color: var(--cyan);
    border-bottom-color: var(--cyan);
  }

  .switcher-cards {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .switcher-card {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .switcher-card.active {
    opacity: 1;
    pointer-events: auto;
  }

  .switcher-card::-webkit-scrollbar { width: 3px; }
  .switcher-card::-webkit-scrollbar-track { background: transparent; }
  .switcher-card::-webkit-scrollbar-thumb { background: var(--border-bright); }

  @keyframes slideInRight {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slideInLeft {
    from { transform: translateX(-100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slideOutLeft {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(-100%); opacity: 0; }
  }

  @keyframes slideOutRight {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(100%); opacity: 0; }
  }

  .anim-in-right { animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .anim-in-left { animation: slideInLeft 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .anim-out-left { animation: slideOutLeft 0.25s cubic-bezier(0.4, 0, 0.2, 1) both; }
  .anim-out-right { animation: slideOutRight 0.25s cubic-bezier(0.4, 0, 0.2, 1) both; }

  .switcher-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--muted);
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    opacity: 1;
    transition: opacity 0.5s ease, max-height 0.5s ease;
    max-height: 40px;
    overflow: hidden;
  }

  .switcher-hint.hidden {
    opacity: 0;
    max-height: 0;
    padding: 0 16px;
    border-bottom: none;
  }

  .switcher-hint kbd {
    display: inline-block;
    padding: 1px 6px;
    border: 1px solid var(--border-bright);
    background: var(--bg2);
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
  }

  .hint-icon {
    font-size: 12px;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .switcher-layout { height: calc(100vh - 64px); margin-top: 64px; }
    .switcher-nav { padding: 0 16px; }

    .switcher-hint { font-size: 9px; padding: 6px 12px; }
    .switcher-hint kbd { font-size: 9px; }
  }
</style>


<script>
(function () {
  const cards = document.querySelectorAll("[data-switcher-card]");
  const navItems = document.querySelectorAll("[data-switcher-target]");
  const hint = document.getElementById("switcherHint");
  let activeIndex = 0;
  let countersTriggered = false;
  let hintDismissed = false;

  function dismissHint() {
    if (!hintDismissed && hint) {
      hintDismissed = true;
      hint.classList.add("hidden");
    }
  }

  function switchTo(index) {
    if (index === activeIndex) return;
    if (index < 0 || index >= cards.length) return;

    dismissHint();

    var direction = index > activeIndex ? "forward" : "backward";
    var oldCard = cards[activeIndex];
    var newCard = cards[index];

    navItems.forEach(function (item, i) {
      item.classList.toggle("active", i === index);
    });

    var sectionName = newCard.getAttribute("data-switcher-card");

    document.querySelectorAll("[data-section]").forEach(function (el) {
      var href = el.getAttribute("href") || "";
      el.classList.toggle(
        "active-link",
        href.replace("#", "") === sectionName
      );
    });

    history.replaceState(null, "", sectionName === "hero" ? "/" : "#" + sectionName);
    activeIndex = index;

    oldCard.classList.remove("active");
    oldCard.classList.add(
      direction === "forward" ? "anim-out-left" : "anim-out-right"
    );
    newCard.classList.add(
      direction === "forward" ? "anim-in-right" : "anim-in-left"
    );

    setTimeout(function () {
      oldCard.classList.remove("anim-out-left", "anim-out-right");
      newCard.classList.remove("anim-in-right", "anim-in-left");
      newCard.classList.add("active");
    }, 450);

    if (sectionName === "hero" && !countersTriggered) {
      countersTriggered = true;
      triggerCounters();
    }
  }

  document.addEventListener("click", function (e) {
    var trigger = e.target.closest(
      "[data-switcher-target], [data-section]"
    );
    if (!trigger) return;

    var target =
      trigger.getAttribute("data-switcher-target") ||
      trigger.getAttribute("data-section");
    if (!target) return;

    var index;
    if (/^\d+$/.test(target)) {
      index = parseInt(target, 10);
    } else {
      index = Array.from(cards).findIndex(function (c) {
        return c.getAttribute("data-switcher-card") === target;
      });
    }

    if (index >= 0) {
      e.preventDefault();
      switchTo(index);
      var mn = document.getElementById("mobileNav");
      var mo = document.getElementById("mobileOverlay");
      var hb = document.getElementById("navHamburger");
      if (mn) mn.classList.remove("active");
      if (mo) mo.classList.remove("active");
      if (hb) hb.classList.remove("active");
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "ArrowDown" || e.key === "ArrowRight") {
      e.preventDefault();
      switchTo(Math.min(activeIndex + 1, cards.length - 1));
    } else if (e.key === "ArrowUp" || e.key === "ArrowLeft") {
      e.preventDefault();
      switchTo(Math.max(activeIndex - 1, 0));
    }
  });

  if (window.location.hash) {
    var section = window.location.hash.replace("#", "");
    var idx = Array.from(cards).findIndex(function (c) {
      return c.getAttribute("data-switcher-card") === section;
    });
    if (idx >= 0) {
      setTimeout(function () {
        switchTo(idx);
      }, 100);
    }
  }

  function triggerCounters() {
    var els = document.querySelectorAll(".stat-num");
    els.forEach(function (el) {
      var text = el.textContent.trim();
      if (text === "11") animateCounter(el, 11);
      else if (text === "128") animateCounter(el, 128);
      else if (text === "25K+") {
        el.textContent = "0K+";
        var c = 0;
        var t = setInterval(function () {
          c++;
          el.textContent = c + "K+";
          if (c >= 25) clearInterval(t);
        }, 30);
      }
    });
  }

  function animateCounter(el, target, suffix) {
    if (suffix === undefined) suffix = "";
    var start = 0;
    var step = target / 60;
    var timer = setInterval(function () {
      start += step;
      if (start >= target) {
        start = target;
        clearInterval(timer);
      }
      el.textContent = Math.floor(start) + suffix;
    }, 16);
  }

  document.body.classList.add("no-switcher-scroll");
})();
</script>
