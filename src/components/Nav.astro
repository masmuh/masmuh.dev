---
interface Props {
  activePath?: string;
  variant?: 'home' | 'default' | 'subpage';
  backHref?: string;
  backText?: string;
  statusText?: string;
}

const {
  activePath = '',
  variant = 'default',
  backHref = '/',
  backText = '← Back',
  statusText = 'Open to Remote',
} = Astro.props;

const isHome = variant === 'home';
const isSubpage = variant === 'subpage';
---

<nav>
  <a href="/" class="nav-logo">MAS<span>.</span>MUH</a>
  {
    isSubpage ? (
      <a href={backHref} class="nav-back">{backText}</a>
    ) : (
      <ul class="nav-links">
        <li><a href={isHome ? '#about' : '/#about'} data-section={isHome ? 'about' : undefined}>About</a></li>
        <li><a href={isHome ? '#skills' : '/#skills'} data-section={isHome ? 'skills' : undefined}>Skills</a></li>
        <li><a href={isHome ? '#experience' : '/#experience'} data-section={isHome ? 'experience' : undefined}>Experience</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/resume">CV</a></li>
        <li><a href="/security" class={activePath === '/security' ? 'active-link' : ''}>Security</a></li>
        <li><a href="/articles" class={activePath === '/articles' ? 'active-link' : ''}>Articles</a></li>
        <li><a href="/uses" class={activePath === '/uses' ? 'active-link' : ''}>Uses</a></li>
        <li><a href={isHome ? '#contact' : '/#contact'} data-section={isHome ? 'contact' : undefined}>Contact</a></li>
      </ul>
    )
  }
  <div class="nav-right">
    {!isSubpage && (
      <div class="nav-status">
        <div class="status-dot"></div>
        {statusText}
      </div>
    )}
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
      <span class="theme-icon-light">☀️</span>
      <span class="theme-icon-dark">🌙</span>
    </button>
    <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-overlay" id="mobileOverlay"></div>
<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <a href="/" class="nav-logo">MAS<span>.</span>MUH</a>
    <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">✕</button>
  </div>
  <ul class="mobile-nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/#about">About</a></li>
    <li><a href="/#skills">Skills</a></li>
    <li><a href="/#experience">Experience</a></li>
    <li><a href="/portfolio">Portfolio</a></li>
    <li><a href="/resume">CV</a></li>
    <li><a href="/security" class={activePath === '/security' ? 'active-link' : ''}>Security</a></li>
    <li><a href="/articles" class={activePath === '/articles' ? 'active-link' : ''}>Articles</a></li>
    <li><a href="/uses" class={activePath === '/uses' ? 'active-link' : ''}>Uses</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
  <button class="mobile-nav-toggle" id="mobileThemeToggle">Toggle Theme</button>
  {!isSubpage && (
    <div class="mobile-nav-status">
      <div class="status-dot"></div>
      {statusText}
    </div>
  )}
</div>

<style>
  .nav-links {
    gap: 24px;
  }
</style>
