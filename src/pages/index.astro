          <span class="skill-tag">NLog</span>
          <span class="skill-tag">Structured Logging</span>
        </div>
      </div>
      <div class="skill-card reveal">
        <div class="skill-card-icon">📄</div>
        <div class="skill-card-title">Reporting & Docs</div>
        <div class="skill-tags">
          <span class="skill-tag">SSRS / RDLC</span>
          <span class="skill-tag">Crystal Reports</span>
          <span class="skill-tag">Aspose.Words</span>
          <span class="skill-tag">iText7</span>
          <span class="skill-tag">EPPlus / NPOI</span>
        </div>
      </div>
      <div class="skill-card reveal">
        <div class="skill-card-icon">🖥️</div>
        <div class="skill-card-title">Frontend Integration</div>
        <div class="skill-tags">
          <span class="skill-tag">React.js</span>
          <span class="skill-tag">Vue.js</span>
          <span class="skill-tag">Tauri / Wails</span>
