---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-logo">MAS<span>.</span>MUH</div>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <div class="nav-status">
      <div class="status-dot"></div>
      Open to Remote
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scan"></div>

    <svg
      class="hero-visual"
      viewBox="0 0 400 400"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle cx="200" cy="200" r="180" stroke="#00c8ff" stroke-width="0.5"
      ></circle>
      <circle
        cx="200"
        cy="200"
        r="140"
        stroke="#00c8ff"
        stroke-width="0.5"
        stroke-dasharray="4 8"></circle>
      <circle cx="200" cy="200" r="100" stroke="#00ff9d" stroke-width="0.5"
      ></circle>
      <circle
        cx="200"
        cy="200"
        r="60"
        stroke="#00c8ff"
        stroke-width="0.5"
        stroke-dasharray="2 6"></circle>
      <circle cx="200" cy="200" r="20" stroke="#00ff9d" stroke-width="1"
      ></circle>
      <!-- Cross hairs -->
      <line
        x1="200"
        y1="10"
        x2="200"
        y2="390"
        stroke="#00c8ff"
        stroke-width="0.3"
        stroke-dasharray="4 12"></line>
      <line
        x1="10"
        y1="200"
        x2="390"
        y2="200"
        stroke="#00c8ff"
        stroke-width="0.3"
        stroke-dasharray="4 12"></line>
      <!-- Corner markers -->
      <rect x="170" y="20" width="60" height="1" fill="#00c8ff"></rect>
      <rect x="170" y="379" width="60" height="1" fill="#00c8ff"></rect>
      <rect x="20" y="170" width="1" height="60" fill="#00c8ff"></rect>
      <rect x="379" y="170" width="1" height="60" fill="#00c8ff"></rect>
      <!-- Dots at intersections -->
      <circle cx="200" cy="20" r="3" fill="#00c8ff"></circle>
      <circle cx="200" cy="380" r="3" fill="#00c8ff"></circle>
      <circle cx="20" cy="200" r="3" fill="#00c8ff"></circle>
      <circle cx="380" cy="200" r="3" fill="#00c8ff"></circle>
      <!-- Diagonal -->
      <line
        x1="74"
        y1="74"
        x2="326"
        y2="326"
        stroke="#00ff9d"
        stroke-width="0.3"
        opacity="0.5"></line>
      <line
        x1="326"
        y1="74"
        x2="74"
        y2="326"
        stroke="#00ff9d"
        stroke-width="0.3"
        opacity="0.5"></line>
    </svg>

    <div class="hero-content">
      <div class="hero-eyebrow">Senior Backend Engineer · Indonesia</div>
      <h1 class="hero-name">
        <span class="glitch" data-text="MAS">MAS</span>
        <span class="line2">MUHAMMAD</span>
      </h1>
      <p class="hero-title">
        <span class="highlight"
          >.NET · Distributed Systems · Containerized Architectures</span
        ><br />
        <span class="hl2">11 years</span> building mission-critical backend infrastructure
        for
        <span class="highlight">Biogen, Sanofi, Shell, Boston Scientific & Sampoerna</span>.<br
        />
        Published author. Remote-work veteran. Currently focused on shipping production-grade AI pipelines and on-device inference tooling.
      </p>
      <div class="hero-badges">
        <span class="badge">.NET Core</span>
        <span class="badge">C# / Go</span>
        <span class="badge">Microservices</span>
        <span class="badge">Docker</span>
        <span class="badge green">100% Delivery Rate</span>
        <span class="badge green">8+ Yrs Remote</span>
      </div>
      <div class="hero-cta">
        <a href="#contact" class="btn-primary">Get In Touch</a>
        <a href="/portfolio" class="btn-secondary">View Portfolio</a>
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">11</div>
        <div class="stat-label">Years Exp.</div>
      </div>
      <div class="stat">
        <div class="stat-num">128</div>
        <div class="stat-label">DB Shards</div>
      </div>
      <div class="stat">
        <div class="stat-num">25K+</div>
        <div class="stat-label">Archives/Mo</div>
      </div>
      <div class="stat">
        <div class="stat-num">4+</div>
        <div class="stat-label">Yrs Zero Critical Downtime</div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="section-header reveal">
      <span class="section-num">01 —</span>
      <h2 class="section-title">About</h2>
      <div class="section-line"></div>
    </div>
    <div class="about-grid">
      <div class="about-text reveal">
        <p>
          Senior Backend Engineer with <strong>11 years of experience</strong> — including
          <strong>2 years as Technical Lead</strong> — specializing in the <span
            class="hl">.NET ecosystem</span
          >, distributed systems, and containerized backend architectures.
        </p>
        <p>
          Proven track record delivering <strong
            >mission-critical, high-availability systems</strong
          > for multinational clients including <span class="hl"
            >Sanofi, Shell, Boston Scientific, and Sampoerna</span
          >.
        </p>
        <p>
          <span class="hl2">Remote work veteran (8+ years)</span> with deep expertise
          in async collaboration, self-directed delivery across global teams, and
          growing proficiency in <span class="hl"
            >shipping production-grade AI pipelines and on-device inference tooling</span
          >.
        </p>
        <p>
          Published author of <em
            >Mastering .NET 10: Modern Backend Development</em
          > — available on Amazon.
        </p>
      </div>
      <div class="terminal reveal">
        <div class="terminal-header">
          <div class="dot r"></div>
          <div class="dot y"></div>
          <div class="dot g"></div>
          <span class="terminal-title">profile.json</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="prompt">❯</span>
            <span class="cmd">cat</span> profile.json
          </div>
          <div class="terminal-line">
            <span class="comment">// mas muhammad — system profile</span>
          </div>
          <div class="terminal-line">
            {}
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"role"</span>: <span class="val"
                >"Senior Backend Engineer"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"experience"</span>: <span
                class="val">"11 years"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"lead_exp"</span>: <span class="val"
                >"2 years"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"primary_stack"</span>: <span
                class="val">".NET / C#"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"secondary"</span>: <span
                class="val">"Go (Golang)"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"remote"</span>: <span class="val"
                >"8+ years"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"location"</span>: <span class="val"
                >"Indonesia 🇮🇩"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"availability"</span>: <span
                class="val">"Open Remote Worldwide"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"downtime_record"</span>: <span
                class="val">"zero critical · 4+ yrs"</span
              >,
            </div>
            <div class="terminal-line">
              &nbsp;&nbsp;<span class="cmd">"delivery_rate"</span>: <span
                class="val">"100%"</span
              >
            </div>
            <div class="terminal-line"></div>
          </div>
          <div class="terminal-line">
            <span class="prompt">❯</span>
            <span class="blink"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ACHIEVEMENTS -->
  <section style="padding-top: 0;">
    <div class="achievements-grid">
      <div class="ach-card reveal">
        <div class="ach-icon">🏆</div>
        <div class="ach-value">25K+</div>
        <div class="ach-label">Archives / Month</div>
        <div class="ach-desc">128 DB shards · Zero downtime · 4+ yrs</div>
      </div>
      <div class="ach-card reveal">
        <div class="ach-icon">⚡</div>
        <div class="ach-value">2M</div>
        <div class="ach-label">Daily Records</div>
        <div class="ach-desc">CSV imports for MSGlow product verification</div>
      </div>
      <div class="ach-card reveal">
        <div class="ach-icon">🚀</div>
        <div class="ach-value">100%</div>
        <div class="ach-label">Delivery Rate</div>
        <div class="ach-desc">Biogen · Sanofi · Shell · Boston Scientific · Sampoerna</div>
      </div>
      <div class="ach-card reveal">
        <div class="ach-icon">📚</div>
        <div class="ach-value">1</div>
        <div class="ach-label">Book Published</div>
        <div class="ach-desc">Mastering .NET 10 — available on Amazon</div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills">
    <div class="section-header reveal">
      <span class="section-num">02 —</span>
      <h2 class="section-title">Tech Stack</h2>
      <div class="section-line"></div>
    </div>
    <div class="skills-grid">
      <div class="skill-card reveal">
        <div class="skill-card-icon">⚙️</div>
