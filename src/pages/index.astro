          <span class="skill-tag">SQL Server</span>
          <span class="skill-tag">PostgreSQL</span>
          <span class="skill-tag">MongoDB</span>
          <span class="skill-tag">Oracle / PL/SQL</span>
          <span class="skill-tag">Redis</span>
          <span class="skill-tag">InfluxDB</span>
          <span class="skill-tag">LiteDB</span>
          <span class="skill-tag">SQLite</span>
        </div>
      </div>
      <div class="skill-card reveal">
        <div class="skill-card-icon">☁️</div>
        <div class="skill-card-title">Cloud & Infra</div>
        <div class="skill-tags">
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Docker Compose</span>
          <span class="skill-tag">Kubernetes / GKE</span>
          <span class="skill-tag">AWS S3</span>
          <span class="skill-tag">Nginx</span>
