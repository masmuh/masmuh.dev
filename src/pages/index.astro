          <span class="skill-tag">CQRS</span>
          <span class="skill-tag">Event Sourcing</span>
          <span class="skill-tag">DDD</span>
          <span class="skill-tag">Multi-Tenancy</span>
          <span class="skill-tag">RESTful API</span>
