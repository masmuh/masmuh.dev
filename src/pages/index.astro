          <span class="skill-tag">Windows Services</span>
          <span class="skill-tag">GitHub Actions</span>
          <span class="skill-tag">GitLab CI</span>
        </div>
      </div>
      <div class="skill-card reveal">
        <div class="skill-card-icon">🤖</div>
        <div class="skill-card-title">AI / ML Integration</div>
        <div class="skill-tags">
          <span class="skill-tag">Whisper.cpp</span>
          <span class="skill-tag">OpenRouter LLM API</span>
          <span class="skill-tag">On-device Inference</span>
          <span class="skill-tag">Multi-model Rotation</span>
          <span class="skill-tag">AI Pipeline Design</span>
        </div>
      </div>
      <div class="skill-card reveal">
        <div class="skill-card-icon">📊</div>
        <div class="skill-card-title">Observability</div>
        <div class="skill-tags">
          <span class="skill-tag">Grafana</span>
