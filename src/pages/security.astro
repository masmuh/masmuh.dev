---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout
  title="Security Analytics Dashboard — Mas Muhammad"
  description="Combined Cloudflare WAF security dashboard for masmuh.web.id"
>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

  <Nav variant="default" activePath="/security" statusText="LIVE" />

  <main class="security-page" id="security-page">
    <div class="wrap">

    <div class="page-header">
      <div class="page-header-left">
        <div class="page-tag">[ SECURITY + ANALYTICS ]</div>
        <h1 class="page-title">Dashboard <span class="dim">Visibility</span></h1>
        <p class="page-subtitle">Real-time view of who's watching masmuh.web.id — legitimate visitors, threats blocked, and engagement patterns. Data from Cloudflare WAF.</p>
        <div style="margin-top:16px">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
        </div>
      </div>
      <div class="page-header-right">
        <div class="last-updated" id="last-updated">Loading Cloudflare data...</div>
        <button class="refresh-btn" id="refresh-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
            <path d="M23 4v6h-6M1 20v-6h6"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          REFRESH DATA
        </button>
      </div>
    </div>

    <section class="section">
      <div class="section-divider">
        <span class="section-tag">[ OVERVIEW ]</span>
        <div class="section-line"></div>
      </div>
      <div class="hero-metrics" id="hero-metrics">
        <div class="metric-card red">
          <div class="metric-icon red">🛡</div>
          <div class="metric-label">Threats Blocked</div>
          <div class="metric-value red" id="m-threats">—</div>
          <div class="metric-sub">last 24 hours</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>
        <div class="metric-card cyan">
          <div class="metric-icon cyan">📡</div>
          <div class="metric-label">Total Requests</div>
          <div class="metric-value cyan" id="m-requests">—</div>
          <div class="metric-sub">last 24 hours</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>

        <div class="metric-card purple">
          <div class="metric-icon purple">🔒</div>
          <div class="metric-label">Block Rate</div>
          <div class="metric-value purple" id="m-blockrate">—</div>
          <div class="metric-sub">of all requests</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>

        <div class="metric-card green">
          <div class="metric-icon green">✅</div>
          <div class="metric-label">Legit Traffic</div>
          <div class="metric-value green" id="m-legit">—</div>
          <div class="metric-sub">clean requests</div>
          <div class="metric-source"><span class="source-badge combined">⬡ COMBINED</span></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-divider">
        <span class="section-tag">[ ANALYTICS ]</span>
        <div class="section-line"></div>
      </div>
      <h2 class="section-title">Traffic 24h — Threats Blocked</h2>
      <div class="card">
        <div id="trafficChart" class="chart-container" style="height:280px"></div>
      </div>
    </section>



    <div class="section two-col">
      <div class="card">
        <div class="card-header">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
          <div class="chart-title" style="margin-top:6px">Top Attacking Countries</div>
          <div class="chart-label">by blocked request volume</div>
        </div>
        <div class="donut-wrap">
          <div class="donut-chart-container">
            <div id="attackDonut" class="chart-container" style="width:140px;height:140px"></div>
            <div class="donut-center">
              <div class="donut-center-val" id="donut-total">—</div>
              <div class="donut-center-label">BLOCKED</div>
            </div>
          </div>
          <div class="donut-legend" id="attack-legend">
            <div class="donut-legend-row"><div class="donut-legend-name"><div class="legend-dot" style="background:#3d5070"></div>—</div><div class="donut-legend-pct">—</div></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
          <div class="chart-title" style="margin-top:6px">Threat Breakdown</div>
          <div class="chart-label">by attack type</div>
        </div>
        <div class="threat-list" id="threat-list">
          <div class="threat-item"><div class="threat-dot" style="background:#f87171"></div><span class="threat-name">—</span><span class="threat-count">—</span><span class="threat-pct">—</span></div>
        </div>
        <div class="security-score-wrap">
          <div class="score-label">Security Score</div>
          <div class="health-score-wrap">
            <div id="scoreGauge" class="chart-container" style="width:110px;height:110px"></div>
            <div class="health-details" id="health-details">
              <div class="health-row"><span class="health-key">WAF Status</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
              <div class="health-row"><span class="health-key">Bot Protection</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
              <div class="health-row"><span class="health-key">Rate Limiting</span><span class="health-val" style="color:#fbbf24">Moderate</span></div>
              <div class="health-row"><span class="health-key">DDoS Shield</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>



    <div class="section">
      <div class="section-divider">
        <span class="section-tag">[ PROTECTION ]</span>
        <div class="section-line"></div>
      </div>
      <h2 class="section-title">Active Security Layers</h2>
      <div class="three-col">
        <div class="card">
          <div class="card-icon">🔥</div>
          <div class="chart-title">Web Application Firewall</div>
          <p class="card-text">Cloudflare WAF inspects every incoming request and blocks common attack patterns using OWASP rules and real-time signature updates.</p>
          <div class="card-tags">
            <span class="tag tag-red">OWASP</span>
            <span class="tag tag-cyan">REAL-TIME</span>
          </div>
        </div>
        <div class="card">
          <div class="card-icon">🤖</div>
          <div class="chart-title">Bot Management</div>
          <p class="card-text">Behavioral fingerprinting and machine learning distinguish legitimate search engine crawlers from malicious bots such as scrapers and attackers.</p>
          <div class="card-tags">
            <span class="tag tag-green">ML-POWERED</span>
            <span class="tag tag-purple">HEURISTIC</span>
          </div>
        </div>
        <div class="card">
          <div class="card-icon">📊</div>
          <div class="chart-title">Analytics &amp; Monitoring</div>
          <p class="card-text">Data from Cloudflare GraphQL API provides comprehensive visibility into threats and visitor behavior.</p>
          <div class="card-tags">
            <span class="tag tag-amber">CLOUDFLARE</span>
          </div>
        </div>
      </div>
    </div>

    </div><!-- /wrap -->
  </main>

  <footer>
    <div class="footer-left"><span>Mas</span>Muhammad © 2026</div>
    <div class="footer-center">Senior Backend Engineer</div>
    <div class="footer-right">
      <a href="/"><span>Home</span></a>
      <span>·</span>
      <a href="/resume"><span>CV</span></a>
      <span>·</span>
      <a href="/security"><span>Security</span></a>
    </div>
  </footer>
</Layout>

<script>
import * as echarts from 'echarts';

const formatNumber = n => n ? n.toLocaleString() : '0';

const COUNTRY_NAMES = {
  US: 'United States', CN: 'China', RU: 'Russia', BR: 'Brazil', IN: 'India',
  ID: 'Indonesia', GB: 'United Kingdom', DE: 'Germany', FR: 'France', JP: 'Japan',
  KR: 'South Korea', SG: 'Singapore', MY: 'Malaysia', PH: 'Philippines', TH: 'Thailand',
  VN: 'Vietnam', NL: 'Netherlands', AU: 'Australia', CA: 'Canada', IT: 'Italy',
  UA: 'Ukraine', IR: 'Iran', IL: 'Israel', TR: 'Turkey', AR: 'Argentina',
  MX: 'Mexico', NG: 'Nigeria', ZA: 'South Africa', BD: 'Bangladesh', PL: 'Poland',
  SE: 'Sweden', NO: 'Norway', FI: 'Finland', CH: 'Switzerland', AT: 'Austria',
  TW: 'Taiwan', HK: 'Hong Kong', RO: 'Romania', HU: 'Hungary', CZ: 'Czech Republic',
  SK: 'Slovakia', SI: 'Slovenia', HR: 'Croatia', BG: 'Bulgaria', GR: 'Greece',
  PT: 'Portugal', ES: 'Spain', BE: 'Belgium', DK: 'Denmark', IE: 'Ireland',
};

const COUNTRY_FLAGS = {
  US: '🇺🇸', CN: '🇨🇳', RU: '🇷🇺', BR: '🇧🇷', IN: '🇮🇳',
  ID: '🇮🇩', GB: '🇬🇧', DE: '🇩🇪', FR: '🇫🇷', JP: '🇯🇵',
  KR: '🇰🇷', SG: '🇸🇬', MY: '🇲🇾', PH: '🇵🇭', TH: '🇹🇭',
  VN: '🇻🇳', NL: '🇳🇱', AU: '🇦🇺', CA: '🇨🇦', IT: '🇮🇹',
  UA: '🇺🇦', IR: '🇮🇷', IL: '🇮🇱', TR: '🇹🇷', AR: '🇦🇷',
  MX: '🇲🇽', NG: '🇳🇬', ZA: '🇿🇦', BD: '🇧🇩', PL: '🇵🇱',
};

function countryName(code) {
  return COUNTRY_NAMES[code] || code || 'Unknown';
}

function flagFor(code) {
  if (!code || code === 'Unknown') return '🌍';
  if (COUNTRY_FLAGS[code]) return COUNTRY_FLAGS[code];
  const l = code.toUpperCase().split('');
  if (l.length === 2) return String.fromCodePoint(0x1F1E6 + l[0].charCodeAt(0) - 65) + String.fromCodePoint(0x1F1E6 + l[1].charCodeAt(0) - 65);
  return '🌍';
}

const SAMPLE_CF = {
  threatsBlocked: 337,
  requestsToday: 627,
  topCountries: [
    { country: 'AU', count: 308 }, { country: 'US', count: 28 },
    { country: 'NL', count: 1 }, { country: 'DE', count: 1 }, { country: 'GB', count: 1 },
  ],
  timeline: [
    { hour: '00:00', count: 12 }, { hour: '01:00', count: 8 }, { hour: '02:00', count: 45 }, { hour: '03:00', count: 28 },
    { hour: '04:00', count: 6 }, { hour: '05:00', count: 25 }, { hour: '06:00', count: 18 }, { hour: '07:00', count: 14 },
    { hour: '08:00', count: 22 }, { hour: '09:00', count: 30 }, { hour: '10:00', count: 28 }, { hour: '11:00', count: 15 },
    { hour: '12:00', count: 10 }, { hour: '13:00', count: 8 }, { hour: '14:00', count: 12 }, { hour: '15:00', count: 18 },
    { hour: '16:00', count: 14 }, { hour: '17:00', count: 10 }, { hour: '18:00', count: 8 }, { hour: '19:00', count: 6 },
    { hour: '20:00', count: 12 }, { hour: '21:00', count: 8 }, { hour: '22:00', count: 6 }, { hour: '23:00', count: 4 },
  ],
  threatsByType: [],
};

// ── ECharts instances ──
let trafficChart, attackDonut, scoreGauge;

function initCharts() {
  [trafficChart, attackDonut, scoreGauge].forEach(c => c?.dispose());
  trafficChart = echarts.init(document.getElementById('trafficChart'));
  attackDonut = echarts.init(document.getElementById('attackDonut'));
  scoreGauge = echarts.init(document.getElementById('scoreGauge'));
}

const EC = {
  bg: 'transparent', text: '#7a90b0', textLight: '#f0f6ff',
  cyan: '#22d3ee', green: '#4ade80', orange: '#fbbf24', red: '#f87171',
  purple: '#a78bfa', blue: '#60a5fa', border: 'rgba(99,179,237,0.15)',
};

// ── CHART RENDERERS ──

function renderTrafficChart(timeline) {
  if (!trafficChart || !timeline) return;
  const labels = timeline.map(t => t.hour ? t.hour.replace(':00','') : '');
  trafficChart.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      trigger: 'axis',
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
    },
    legend: { show: false },
    grid: { left: 50, right: 16, top: 10, bottom: 24 },
    xAxis: {
      type: 'category', data: labels,
      axisLine: { lineStyle: { color: EC.border } },
      axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 10, interval: 2 },
    },
    yAxis: {
      type: 'value', splitLine: { lineStyle: { color: EC.border, type: 'dashed', opacity: 0.6 } },
      axisLine: { show: false }, axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 10 },
    },
    series: [
      { name: 'Threats Blocked', type: 'bar', barWidth: '30%',
        data: timeline.map(t => t.count),
        itemStyle: { color: EC.red, borderRadius: [3,3,0,0], opacity: 0.9 } },
    ],
  });
}

function renderAttackDonut(countries) {
  if (!attackDonut || !countries) return;
  const colors = ['#f87171','#fbbf24','#a78bfa','#60a5fa','#94a3b8'];
  const total = countries.reduce((s, c) => s + c.count, 0);
  document.getElementById('donut-total').textContent = formatNumber(total);
  const data = countries.slice(0, 5).map((c, i) => ({
    name: countryName(c.country),
    value: c.count,
    itemStyle: { color: colors[i] },
  }));
  attackDonut.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
      formatter: p => p.name + ': ' + formatNumber(p.value) + ' (' + ((p.value / total) * 100).toFixed(1) + '%)',
    },
    series: [{
      type: 'pie', radius: ['55%', '75%'], center: ['50%', '50%'],
      avoidLabelOverlap: true,
      label: { show: false },
      emphasis: { itemStyle: { shadowBlur: 8, shadowColor: 'rgba(0,0,0,0.3)' } },
      data,
    }],
  });
  const legendEl = document.getElementById('attack-legend');
  legendEl.innerHTML = '';
  data.forEach((d, i) => {
    const row = document.createElement('div');
    row.className = 'donut-legend-row';
    const code = countries[i].country;
    row.innerHTML =
      '<div class="donut-legend-name"><div class="legend-dot" style="background:' + colors[i] + '"></div>' + code + ' ' + d.name + '</div>' +
      '<div class="donut-legend-pct" style="color:' + colors[i] + '">' + ((d.value / total) * 100).toFixed(1) + '%</div>';
    legendEl.appendChild(row);
  });
}

function renderScoreGauge(score) {
  if (!scoreGauge) return;
  scoreGauge.setOption({
    backgroundColor: EC.bg,
    series: [{
      type: 'gauge', startAngle: 90, endAngle: -270,
      pointer: { show: false },
      progress: { show: true, width: 8, roundCap: true },
      axisLine: { lineStyle: { width: 8, color: [[1, 'rgba(99,179,237,0.1)']] } },
      axisTick: { show: false },
      splitLine: { show: false },
      axisLabel: { show: false },
      detail: {
        offsetCenter: [0, 0], fontSize: 22, fontWeight: 700, fontFamily: 'Space Mono',
        color: '#4ade80', formatter: '{value}',
      },
      data: [{ value: score }],
    }],
  });
}

// ── UI POPULATE ──

function populateMetrics(cf) {
  const t = cf?.threatsBlocked || SAMPLE_CF.threatsBlocked;
  const r = cf?.requestsToday || SAMPLE_CF.requestsToday;
  const rate = r > 0 ? ((t / r) * 100).toFixed(1) + '%' : '0%';
  document.getElementById('m-threats').textContent = formatNumber(t);
  document.getElementById('m-requests').textContent = formatNumber(r);
  document.getElementById('m-blockrate').textContent = rate;
  document.getElementById('m-legit').textContent = (100 - parseFloat(rate)).toFixed(1) + '%';
}

const ACTION_LABELS = {
  block: 'Blocked', challenge: 'Challenge Issued', jschallenge: 'JS Challenge',
  managed_challenge: 'Managed Challenge', log: 'Logged', bypass: 'Bypassed',
};

const ACTION_COLORS = {
  block: '#f87171', challenge: '#fbbf24', jschallenge: '#a78bfa',
  managed_challenge: '#60a5fa', log: '#94a3b8', bypass: '#34d399',
};

function populateThreats(cf) {
  const types = cf?.threatsByType;
  const el = document.getElementById('threat-list');
  el.innerHTML = '';

  if (!types || types.length === 0) {
    const item = document.createElement('div');
    item.className = 'threat-item';
    item.style.justifyContent = 'center';
    item.style.padding = '16px 14px';
    item.innerHTML = '<span style="color:var(--text-muted);font-size:12px">No threat breakdown data available (Free plan)</span>';
    el.appendChild(item);
    return;
  }

  const total = types.reduce((s, t) => s + t.count, 0);
  types.forEach(t => {
    const label = ACTION_LABELS[t.name] || t.name;
    const color = ACTION_COLORS[t.name] || '#94a3b8';
    const pct = total > 0 ? ((t.count / total) * 100).toFixed(1) + '%' : '—';
    const item = document.createElement('div');
    item.className = 'threat-item';
    item.innerHTML =
      '<div class="threat-dot" style="background:' + color + '"></div>' +
      '<span class="threat-name">' + label + '</span>' +
      '<span class="threat-count" style="color:' + color + '">' + formatNumber(t.count) + '</span>' +
      '<span class="threat-pct">' + pct + '</span>';
    el.appendChild(item);
  });
}

function populateUI(cf) {
  populateMetrics(cf);
  populateThreats(cf);

  renderTrafficChart(cf?.timeline || SAMPLE_CF.timeline);
  renderAttackDonut(cf?.topCountries || SAMPLE_CF.topCountries);
  const score = cf ? 90 : 0;
  renderScoreGauge(score);
}

async function loadData() {
  const refreshBtn = document.getElementById('refresh-btn');
  const lastUpdated = document.getElementById('last-updated');
  if (refreshBtn) refreshBtn.disabled = true;
  if (lastUpdated) lastUpdated.textContent = 'Connecting to Cloudflare...';

  const cfRes = await fetch('/.netlify/functions/security').then(r => { if (!r.ok) throw Error(); return r.json(); }).catch(() => null);

  populateUI(cfRes);

  if (lastUpdated) {
    if (!cfRes) {
      lastUpdated.textContent = 'Sample data — API unavailable.';
    } else {
      lastUpdated.textContent = 'Live: Cloudflare • ' + new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + ' WIB';
    }
  }
  if (refreshBtn) refreshBtn.disabled = false;
}

initCharts();
window.addEventListener('resize', () => {
  [trafficChart, attackDonut, scoreGauge].forEach(c => c?.resize());
});
document.getElementById('refresh-btn')?.addEventListener('click', loadData);
loadData();
</script>

<style is:global>
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(34,211,238,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(34,211,238,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

.security-page {
  padding-top: 100px;
  --text-primary: #f0f6ff;
  --text-secondary: #7a90b0;
  --text-muted: #3d5070;
  --bg-card: #111827;
  --border: rgba(99,179,237,0.12);
  --red: #f87171;
  --amber: #fbbf24;
  --purple: #a78bfa;
  --blue: #60a5fa;
  --cyan: #22d3ee;
  --green: #4ade80;
  --glow: rgba(34,211,238,0.15);
}

.wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  position: relative;
  z-index: 1;
}

.page-header {
  padding: 20px 0 32px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.page-tag {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--cyan);
  letter-spacing: 0.15em;
  margin-bottom: 10px;
  opacity: 0.8;
}

.page-title {
  font-size: 42px;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--text-primary);
  font-family: 'DM Sans', sans-serif;
}

.page-title .dim { color: var(--text-muted); }

.page-subtitle {
  margin-top: 8px;
  font-size: 14px;
  color: var(--text-secondary);
  max-width: 520px;
  line-height: 1.6;
  font-family: 'DM Sans', sans-serif;
}

.page-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.last-updated {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--text-muted);
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: transparent;
  border: 1px solid rgba(56,189,248,0.3);
  border-radius: 6px;
  color: var(--cyan);
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: all 0.2s;
}

.refresh-btn:hover { background: var(--glow); }
.refresh-btn:disabled { opacity: 0.5; cursor: wait; }

.source-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 9px;
  border-radius: 4px;
  font-size: 10px;
  letter-spacing: 0.06em;
  font-family: 'Space Mono', monospace;
}

.source-badge.cf { background: rgba(248,113,113,0.12); color: #fca5a5; }
.source-badge.combined { background: rgba(167,139,250,0.12); color: #c4b5fd; }

.section { margin-bottom: 40px; padding: 0; }

.section-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.section-tag {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

.section-title {
  font-size: 26px;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-bottom: 20px;
  color: var(--text-primary);
  font-family: 'DM Sans', sans-serif;
}

.card {
  background: var(--bg-card);
