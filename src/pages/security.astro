      <p class="last-updated" id="last-updated">Loading Cloudflare analytics...</p>
    </section>
  </main>

  <footer>
    <div class="footer-left">
      <span>Mas</span>Muhammad ¬© 2026
    </div>
    <div class="footer-center">Senior Backend Engineer</div>
    <div class="footer-right">
      <a href="/"><span>Home</span></a>
      <span>¬Ј</span>
      <a href="/resume"><span>CV</span></a>
      <span>¬Ј</span>
      <a href="/security"><span>Security</span></a>
    </div>
  </footer>
</Layout>

<script>
const formatNumber = n => n.toLocaleString();

const COUNTRY_NAMES = {
  US: 'United States', CN: 'China', RU: 'Russia', BR: 'Brazil', IN: 'India',
  ID: 'Indonesia', GB: 'United Kingdom', DE: 'Germany', FR: 'France', JP: 'Japan',
  KR: 'South Korea', SG: 'Singapore', MY: 'Malaysia', PH: 'Philippines', TH: 'Thailand',
  VN: 'Vietnam', NL: 'Netherlands', AU: 'Australia', CA: 'Canada', IT: 'Italy',
  UA: 'Ukraine', IR: 'Iran', IL: 'Israel', TR: 'Turkey', AR: 'Argentina',
  MX: 'Mexico', NG: 'Nigeria', ZA: 'South Africa', BD: 'Bangladesh', PL: 'Poland',
  SE: 'Sweden', NO: 'Norway', FI: 'Finland', CH: 'Switzerland', AT: 'Austria',
  TW: 'Taiwan', HK: 'Hong Kong', RO: 'Romania', HU: 'Hungary', CZ: 'Czech Republic',
  SK: 'Slovakia', SI: 'Slovenia', HR: 'Croatia', BG: 'Bulgaria', GR: 'Greece',
  PT: 'Portugal', ES: 'Spain', BE: 'Belgium', DK: 'Denmark', IE: 'Ireland',
};

const COUNTRY_FLAGS = {
  US: 'рЯЗЇрЯЗЄ', CN: 'рЯЗ®рЯЗ≥', RU: 'рЯЗЈрЯЗЇ', BR: 'рЯЗІрЯЗЈ', IN: 'рЯЗЃрЯЗ≥',
  ID: 'рЯЗЃрЯЗ©', GB: 'рЯЗђрЯЗІ', DE: 'рЯЗ©рЯЗ™', FR: 'рЯЗЂрЯЗЈ', JP: 'рЯЗѓрЯЗµ',
  KR: 'рЯЗ∞рЯЗЈ', SG: 'рЯЗЄрЯЗђ', MY: 'рЯЗ≤рЯЗЊ', PH: 'рЯЗµрЯЗ≠', TH: 'рЯЗєрЯЗ≠',
  VN: 'рЯЗїрЯЗ≥', NL: 'рЯЗ≥рЯЗ±', AU: 'рЯЗ¶рЯЗЇ', CA: 'рЯЗ®рЯЗ¶', IT: 'рЯЗЃрЯЗє',
  UA: 'рЯЗЇрЯЗ¶', IR: 'рЯЗЃрЯЗЈ', IL: 'рЯЗЃрЯЗ±', TR: 'рЯЗєрЯЗЈ', AR: 'рЯЗ¶рЯЗЈ',
  MX: 'рЯЗ≤рЯЗљ', NG: 'рЯЗ≥рЯЗђ', ZA: 'рЯЗњрЯЗ¶', BD: 'рЯЗІрЯЗ©', PL: 'рЯЗµрЯЗ±',
  SE: 'рЯЗЄрЯЗ™', NO: 'рЯЗ≥рЯЗі', FI: 'рЯЗЂрЯЗЃ', CH: 'рЯЗ®рЯЗ≠', AT: 'рЯЗ¶рЯЗє',
  TW: 'рЯЗєрЯЗЉ', HK: 'рЯЗ≠рЯЗ∞', RO: 'рЯЗЈрЯЗі', HU: 'рЯЗ≠рЯЗЇ', CZ: 'рЯЗ®рЯЗњ',
  SK: 'рЯЗЄрЯЗ∞', SI: 'рЯЗЄрЯЗЃ', HR: 'рЯЗ≠рЯЗЈ', BG: 'рЯЗІрЯЗђ', GR: 'рЯЗђрЯЗЈ',
  PT: 'рЯЗµрЯЗє', ES: 'рЯЗ™рЯЗЄ', BE: 'рЯЗІрЯЗ™', DK: 'рЯЗ©рЯЗ∞', IE: 'рЯЗЃрЯЗ™',
};

function countryName(code) {
  return COUNTRY_NAMES[code] || code || 'Unknown';
}

function flagFor(code) {
  if (!code || code === 'Unknown') return 'рЯМН';
  if (COUNTRY_FLAGS[code]) return COUNTRY_FLAGS[code];
  const l = code.toUpperCase().split('');
  if (l.length === 2) return String.fromCodePoint(0x1F1E6 + l[0].charCodeAt(0) - 65) + String.fromCodePoint(0x1F1E6 + l[1].charCodeAt(0) - 65);
  return 'рЯМН';
}

// Sample data for local dev fallback
const SAMPLE = {
  threatsBlocked: 12847,
  requestsToday: 4291,
  timeline: [
    { hour: '00:00', count: 42 }, { hour: '01:00', count: 38 },
    { hour: '02:00', count: 25 }, { hour: '03:00', count: 18 },
    { hour: '04:00', count: 22 }, { hour: '05:00', count: 31 },
    { hour: '06:00', count: 45 }, { hour: '07:00', count: 67 },
    { hour: '08:00', count: 89 }, { hour: '09:00', count: 120 },
    { hour: '10:00', count: 145 }, { hour: '11:00', count: 132 },
    { hour: '12:00', count: 98 }, { hour: '13:00', count: 87 },
    { hour: '14:00', count: 112 }, { hour: '15:00', count: 95 },
    { hour: '16:00', count: 78 }, { hour: '17:00', count: 65 },
    { hour: '18:00', count: 54 }, { hour: '19:00', count: 48 },
    { hour: '20:00', count: 52 }, { hour: '21:00', count: 43 },
    { hour: '22:00', count: 38 }, { hour: '23:00', count: 29 },
  ],
  topCountries: [
    { country: 'ID', count: 4291 }, { country: 'CN', count: 2156 },
    { country: 'RU', count: 1843 }, { country: 'US', count: 1247 },
    { country: 'BR', count: 956 },
  ],
};

function populateUI(data) {
  document.getElementById('stat-threats').textContent = formatNumber(data.threatsBlocked);
  document.getElementById('stat-requests').textContent = formatNumber(data.requestsToday);

  const rate = data.requestsToday > 0
    ? ((data.threatsBlocked / data.requestsToday) * 100).toFixed(1) + '%'
    : '0%';
  document.getElementById('stat-rate').textContent = rate;

  const top = data.topCountries?.[0];
  const topEl = document.getElementById('stat-top-country');
  if (top && top.country) {
    topEl.textContent = flagFor(top.country) + ' ' + countryName(top.country);
  }

  // Timeline
  const barsEl = document.getElementById('timeline-bars');
  const labelsEl = document.getElementById('timeline-labels');
  if (data.timeline && barsEl) {
    const maxC = Math.max(...data.timeline.map(t => t.count), 1);
    barsEl.innerHTML = '';
    labelsEl.innerHTML = '';
    for (const t of data.timeline) {
      const pct = (t.count / maxC) * 85 + 5;
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      bar.style.setProperty('--height', pct + '%');
      bar.innerHTML = `<span class="bar-tooltip">${formatNumber(t.count)}</span>`;
      barsEl.appendChild(bar);
      const lbl = document.createElement('span');
      lbl.textContent = t.hour;
      labelsEl.appendChild(lbl);
    }
  }

  // Countries bar chart
  const cEl = document.getElementById('countries-chart');
  if (data.topCountries && cEl) {
    cEl.innerHTML = '';
    const maxC = Math.max(...data.topCountries.map(c => c.count), 1);
    data.topCountries.slice(0, 5).forEach((c, i) => {
      const pct = (c.count / maxC) * 100;
      const item = document.createElement('div');
      item.className = 'country-bar-item';
      item.innerHTML = `
        <span class="country-bar-rank">#${i + 1}</span>
        <span class="country-bar-flag">${flagFor(c.country)}</span>
        <span class="country-bar-name">${countryName(c.country)}</span>
        <div class="country-bar-track">
          <div class="country-bar-fill" style="width:${pct}%"></div>
        </div>
        <span class="country-bar-count">${formatNumber(c.count)}</span>`;
      cEl.appendChild(item);
    });
  }
}

async function loadData() {
  const refreshBtn = document.getElementById('refresh-btn');
  const lastUpdated = document.getElementById('last-updated');
  if (refreshBtn) refreshBtn.disabled = true;
  if (lastUpdated) lastUpdated.textContent = 'Connecting to Cloudflare...';

  try {
    const res = await fetch('/.netlify/functions/security');
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    populateUI(data);
    if (lastUpdated) lastUpdated.textContent = 'Last updated: ' + new Date().toLocaleTimeString();
  } catch {
    populateUI(SAMPLE);
    if (lastUpdated) lastUpdated.textContent = 'Sample data вАФ connect to Netlify for live updates.';
  } finally {
    if (refreshBtn) refreshBtn.disabled = false;
  }
}

document.getElementById('refresh-btn')?.addEventListener('click', loadData);
loadData();
</script>

<style>
  .security-page {
    padding-top: 100px;
  }

  .security-hero {
    padding: 60px;
  }

  .security-intro {
    margin-bottom: 60px;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 32px;
  }

  .intro-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--white);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .intro-text strong {
    color: var(--cyan);
  }

  .intro-text code {
    font-family: var(--font-mono);
    color: var(--green);
    font-size: 12px;
  }

  .intro-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .intro-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
  }

  .intro-icon {
    font-size: 24px;
    flex-shrink: 0;
  }

  .intro-item div {
    flex: 1;
  }

  .intro-item strong {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--cyan);
    text-transform: uppercase;
    display: block;
    margin-bottom: 6px;
  }

  .intro-item p {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .security-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--cyan);
    opacity: 0.5;
  }

  .stat-card:hover {
    border-color: var(--border-bright);
    transform: translateY(-4px);
  }

  .stat-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -2px;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  .stat-trend {
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: 12px;
    padding: 4px 10px;
    display: inline-block;
    clip-path: polygon(4px 0%, 100% 0%, calc(100% - 4px) 100%, 0% 100%);
  }

  .stat-trend.positive {
    background: rgba(0, 255, 157, 0.1);
    color: var(--green);
    border: 1px solid rgba(0, 255, 157, 0.3);
  }

  .stat-trend.negative {
    background: rgba(255, 107, 53, 0.1);
    color: var(--orange);
    border: 1px solid rgba(255, 107, 53, 0.3);
  }

  .stat-trend.neutral {
    background: rgba(0, 200, 255, 0.1);
    color: var(--cyan);
    border: 1px solid var(--border-bright);
  }

  .threat-blocked .stat-value { color: var(--cyan); }
  .bot-traffic .stat-value { color: var(--orange); }
  .top-attacker .stat-value { font-size: 36px; }

  .stat-value--country {
    font-size: 32px;
    letter-spacing: -1px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Timeline Section */
  .timeline-section {
    padding: 60px;
  }

  .timeline-chart {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 32px;
  }

  .chart-body {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }

  .chart-y-axis {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-bottom: 36px;
    width: 40px;
    flex-shrink: 0;
  }

  .chart-y-axis span {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    text-align: right;
  }

  .chart-main {
    flex: 1;
    min-width: 0;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 200px;
    gap: 4px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .chart-bars::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to top,
      transparent,
      transparent 24%,
      var(--border) 24%,
      var(--border) 25%
    );
    opacity: 0.15;
    pointer-events: none;
  }

  .chart-bar {
    flex: 1;
    height: var(--height);
    background: linear-gradient(to top, var(--cyan), var(--green));
    position: relative;
    transition: all 0.3s;
    cursor: pointer;
    min-height: 6px;
    border-radius: 2px 2px 0 0;
  }

  .chart-bar:hover {
    opacity: 0.85;
    transform: scaleY(1.03);
  }

  .bar-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    border: 1px solid var(--border-bright);
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .chart-bar:hover .bar-tooltip {
    opacity: 1;
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
  }

  .chart-labels span {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    flex: 1;
    text-align: center;
  }

  /* Countries Bar Chart */
  .countries-section {
    padding: 60px;
  }

  .countries-chart {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px 28px;
  }

  .country-bar-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .country-bar-item:last-child {
    border-bottom: none;
  }

  .country-bar-rank {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    width: 28px;
    flex-shrink: 0;
  }

  .country-bar-flag {
    font-size: 20px;
    flex-shrink: 0;
  }

  .country-bar-name {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--white);
    width: 130px;
    flex-shrink: 0;
  }

  .country-bar-track {
    flex: 1;
    height: 20px;
    background: var(--bg2);
    border-radius: 2px;
    overflow: hidden;
  }

  .country-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--cyan), var(--green));
    border-radius: 2px;
    transition: width 0.6s ease;
  }

  .country-bar-count {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    width: 80px;
    text-align: right;
    flex-shrink: 0;
  }

  /* Refresh Section */
  .refresh-section {
    padding: 60px;
    display: flex;
