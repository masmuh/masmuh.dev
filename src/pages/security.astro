---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Security Analytics Dashboard — Mas Muhammad"
  description="Combined Cloudflare WAF security & Google Analytics 4 traffic dashboard for masmuh.web.id"
>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

  <nav>
    <a href="/" class="nav-logo">Mas<span>.</span>ID</a>
    <ul class="nav-links">
      <li><a href="/">About</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/resume">CV</a></li>
      <li><a href="/security" class="active-link">Security</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <div class="nav-right">
      <div class="nav-status">
        <span class="status-dot"></span>
        LIVE
      </div>
      <button class="theme-toggle" id="themeToggle" title="Toggle theme">
        <span class="theme-icon-dark">☀</span>
        <span class="theme-icon-light">☾</span>
      </button>
    </div>
  </nav>

  <main class="security-page" id="security-page">

    <div class="page-header">
      <div class="page-header-left">
        <div class="page-tag">[ SECURITY + ANALYTICS ]</div>
        <h1 class="page-title">Dashboard <span class="dim">Visibility</span></h1>
        <p class="page-subtitle">Real-time view of who's watching masmuh.web.id — legitimate visitors, threats blocked, and engagement patterns. Data dari Cloudflare WAF &amp; Google Analytics 4.</p>
        <div style="margin-top:16px">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
          <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
        </div>
      </div>
      <div class="page-header-right">
        <div class="last-updated" id="last-updated">Loading Cloudflare &amp; GA4 data...</div>
        <button class="refresh-btn" id="refresh-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
            <path d="M23 4v6h-6M1 20v-6h6"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          REFRESH DATA
        </button>
      </div>
    </div>

    <section class="section">
      <div class="section-divider">
        <span class="section-tag">[ OVERVIEW ]</span>
        <div class="section-line"></div>
      </div>
      <div class="hero-metrics" id="hero-metrics">
        <div class="metric-card red">
          <div class="metric-icon red">🛡</div>
          <div class="metric-label">Threats Blocked</div>
          <div class="metric-value red" id="m-threats">—</div>
          <div class="metric-sub">last 24 hours</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>
        <div class="metric-card cyan">
          <div class="metric-icon cyan">📡</div>
          <div class="metric-label">Total Requests</div>
          <div class="metric-value cyan" id="m-requests">—</div>
          <div class="metric-sub">last 24 hours</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>
        <div class="metric-card green">
          <div class="metric-icon green">👤</div>
          <div class="metric-label">Active Users</div>
          <div class="metric-value green" id="m-users">—</div>
          <div class="metric-sub">28-day window</div>
          <div class="metric-source"><span class="source-badge ga">📊 GOOGLE ANALYTICS</span></div>
        </div>
        <div class="metric-card blue">
          <div class="metric-icon blue">✨</div>
          <div class="metric-label">New Visitors</div>
          <div class="metric-value blue" id="m-new">—</div>
          <div class="metric-sub">new users</div>
          <div class="metric-source"><span class="source-badge ga">📊 GOOGLE ANALYTICS</span></div>
        </div>
        <div class="metric-card amber">
          <div class="metric-icon amber">⏱</div>
          <div class="metric-label">Avg. Engagement</div>
          <div class="metric-value amber" id="m-engage">—</div>
          <div class="metric-sub">per session</div>
          <div class="metric-source"><span class="source-badge ga">📊 GOOGLE ANALYTICS</span></div>
        </div>
        <div class="metric-card purple">
          <div class="metric-icon purple">🔒</div>
          <div class="metric-label">Block Rate</div>
          <div class="metric-value purple" id="m-blockrate">—</div>
          <div class="metric-sub">of all requests</div>
          <div class="metric-source"><span class="source-badge cf">⚡ CLOUDFLARE</span></div>
        </div>
        <div class="metric-card cyan">
          <div class="metric-icon cyan">📌</div>
          <div class="metric-label">Total Events</div>
          <div class="metric-value cyan" id="m-events">—</div>
          <div class="metric-sub">page interactions</div>
          <div class="metric-source"><span class="source-badge ga">📊 GOOGLE ANALYTICS</span></div>
        </div>
        <div class="metric-card green">
          <div class="metric-icon green">✅</div>
          <div class="metric-label">Legit Traffic</div>
          <div class="metric-value green" id="m-legit">—</div>
          <div class="metric-sub">clean requests</div>
          <div class="metric-source"><span class="source-badge combined">⬡ COMBINED</span></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-divider">
        <span class="section-tag">[ ANALYTICS ]</span>
        <div class="section-line"></div>
      </div>
      <h2 class="section-title">Traffic 24h — Blocked vs Legitimate</h2>
      <div class="card">
        <div class="legend">
          <div class="legend-item"><div class="legend-dot" style="background:#f87171"></div> Threats Blocked (CF)</div>
          <div class="legend-item"><div class="legend-dot" style="background:#22d3ee"></div> Legitimate Requests (CF)</div>
          <div class="legend-item"><div class="legend-dot" style="background:#4ade80;border-radius:50%"></div> Unique Visitors (GA)</div>
        </div>
        <div id="trafficChart" class="chart-container" style="height:280px"></div>
      </div>
    </section>

    <div class="section two-thirds">
      <div class="card">
        <div class="card-header">
          <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
          <div class="chart-title" style="margin-top:6px">Top Pages</div>
          <div class="chart-label">by pageviews &amp; bounce rate</div>
        </div>
        <table class="data-table">
          <thead>
            <tr><th>Page</th><th style="text-align:right">Views</th><th style="text-align:right">Users</th><th style="text-align:right">Bounce</th></tr>
          </thead>
          <tbody id="pages-body">
            <tr><td class="page-name">—</td><td class="num">—</td><td class="num">—</td><td class="num">—</td></tr>
          </tbody>
        </table>
      </div>
      <div class="right-col">
        <div class="card">
          <div class="card-header">
            <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
            <div class="chart-title" style="margin-top:6px">Top Cities</div>
          </div>
          <div class="city-grid" id="cities-grid">
            <div class="city-row"><span class="city-rank">—</span><span class="city-name">—</span><div class="city-bar-wrap"><div class="city-bar"><div class="city-bar-fill" style="width:0%"></div></div></div><span class="city-count">—</span></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
            <div class="chart-title" style="margin-top:6px">Engagement Stats</div>
          </div>
          <div class="engagement-grid" id="engagement-grid">
            <div class="eng-item"><div class="eng-val" id="eng-active">—</div><div class="eng-label">Active</div></div>
            <div class="eng-item"><div class="eng-val" id="eng-new">—</div><div class="eng-label">New</div></div>
            <div class="eng-item"><div class="eng-val" id="eng-sessions">—</div><div class="eng-label">Sessions</div></div>
          </div>
          <div class="progress-group" id="progress-group">
            <div class="progress-row">
              <div class="progress-label-row"><span>Returning visitors</span><span id="ret-pct" style="color:#4ade80">—</span></div>
              <div class="progress-bar"><div class="progress-fill" id="ret-fill" style="width:0%;background:#4ade80"></div></div>
            </div>
            <div class="progress-row">
              <div class="progress-label-row"><span>New visitors</span><span id="new-pct" style="color:#60a5fa">—</span></div>
              <div class="progress-bar"><div class="progress-fill" id="new-fill" style="width:0%;background:#60a5fa"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="section two-col">
      <div class="card">
        <div class="card-header">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
          <div class="chart-title" style="margin-top:6px">Top Attacking Countries</div>
          <div class="chart-label">by blocked request volume</div>
        </div>
        <div class="donut-wrap">
          <div class="donut-chart-container">
            <div id="attackDonut" class="chart-container" style="width:160px;height:160px"></div>
            <div class="donut-center">
              <div class="donut-center-val" id="donut-total">—</div>
              <div class="donut-center-label">BLOCKED</div>
            </div>
          </div>
          <div class="donut-legend" id="attack-legend">
            <div class="donut-legend-row"><div class="donut-legend-name"><div class="legend-dot" style="background:#3d5070"></div>—</div><div class="donut-legend-pct">—</div></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="source-badge cf">⚡ CLOUDFLARE</span>
          <div class="chart-title" style="margin-top:6px">Threat Breakdown</div>
          <div class="chart-label">by attack type</div>
        </div>
        <div class="threat-list" id="threat-list">
          <div class="threat-item"><div class="threat-dot" style="background:#f87171"></div><span class="threat-name">—</span><span class="threat-count">—</span><span class="threat-pct">—</span></div>
        </div>
        <div class="security-score-wrap">
          <div class="score-label">Security Score</div>
          <div class="health-score-wrap">
            <div id="scoreGauge" class="chart-container" style="width:110px;height:110px"></div>
            <div class="health-details" id="health-details">
              <div class="health-row"><span class="health-key">WAF Status</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
              <div class="health-row"><span class="health-key">Bot Protection</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
              <div class="health-row"><span class="health-key">Rate Limiting</span><span class="health-val" style="color:#fbbf24">Moderate</span></div>
              <div class="health-row"><span class="health-key">DDoS Shield</span><span class="health-val" style="color:#4ade80">Active ✓</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="section two-col">
      <div class="card">
        <div class="card-header">
          <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
          <div class="chart-title" style="margin-top:6px">Visitor Traffic Source</div>
          <div class="chart-label">by acquisition channel</div>
        </div>
        <div class="donut-wrap">
          <div class="donut-chart-container">
            <div id="sourceDonut" class="chart-container" style="width:160px;height:160px"></div>
            <div class="donut-center">
              <div class="donut-center-val" id="source-total">—</div>
              <div class="donut-center-label">USERS</div>
            </div>
          </div>
          <div class="donut-legend" id="source-legend">
            <div class="donut-legend-row"><div class="donut-legend-name"><div class="legend-dot" style="background:#3d5070"></div>—</div><div class="donut-legend-pct">—</div></div>
          </div>
        </div>
        <div class="insight-box">
          💡 <strong>Insight:</strong> Semua traffic dari Direct berarti pengunjung sudah tahu URL-mu. Pertimbangkan SEO atau sharing link untuk memperluas jangkauan.
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="source-badge ga">📊 GOOGLE ANALYTICS</span>
          <div class="chart-title" style="margin-top:6px">New vs Returning Users</div>
          <div class="chart-label">28-day trend</div>
        </div>
        <div class="legend">
          <div class="legend-item"><div class="legend-dot" style="background:#22d3ee"></div> New Users</div>
          <div class="legend-item"><div class="legend-dot" style="background:#4ade80;border-radius:50%"></div> Returning</div>
        </div>
        <div id="trendChart" class="chart-container" style="height:200px"></div>
      </div>
    </div>

    <div class="section">
      <div class="section-divider">
        <span class="section-tag">[ PROTECTION ]</span>
        <div class="section-line"></div>
      </div>
      <h2 class="section-title">Active Security Layers</h2>
      <div class="three-col">
        <div class="card">
          <div class="card-icon">🔥</div>
          <div class="chart-title">Web Application Firewall</div>
          <p class="card-text">Cloudflare WAF inspects every incoming request and blocks common attack patterns using OWASP rules and real-time signature updates.</p>
          <div class="card-tags">
            <span class="tag tag-red">OWASP</span>
            <span class="tag tag-cyan">REAL-TIME</span>
          </div>
        </div>
        <div class="card">
          <div class="card-icon">🤖</div>
          <div class="chart-title">Bot Management</div>
          <p class="card-text">Behavioral fingerprinting dan machine learning membedakan search engine crawler dari bot jahat seperti scrapers dan attackers.</p>
          <div class="card-tags">
            <span class="tag tag-green">ML-POWERED</span>
            <span class="tag tag-purple">HEURISTIC</span>
          </div>
        </div>
        <div class="card">
          <div class="card-icon">📊</div>
          <div class="chart-title">Analytics &amp; Monitoring</div>
          <p class="card-text">Data dari Cloudflare GraphQL API + Google Analytics 4 memberikan visibilitas menyeluruh terhadap ancaman dan perilaku pengunjung.</p>
          <div class="card-tags">
            <span class="tag tag-amber">CLOUDFLARE</span>
            <span class="tag tag-blue">GA4</span>
          </div>
        </div>
      </div>
    </div>

  </main>

  <footer>
    <div class="footer-left"><span>Mas</span>Muhammad © 2026</div>
    <div class="footer-center">Senior Backend Engineer</div>
    <div class="footer-right">
      <a href="/"><span>Home</span></a>
      <span>·</span>
      <a href="/resume"><span>CV</span></a>
      <span>·</span>
      <a href="/security"><span>Security</span></a>
    </div>
  </footer>
</Layout>

<script>
import * as echarts from 'echarts';

const formatNumber = n => n ? n.toLocaleString() : '0';

const COUNTRY_NAMES = {
  US: 'United States', CN: 'China', RU: 'Russia', BR: 'Brazil', IN: 'India',
  ID: 'Indonesia', GB: 'United Kingdom', DE: 'Germany', FR: 'France', JP: 'Japan',
  KR: 'South Korea', SG: 'Singapore', MY: 'Malaysia', PH: 'Philippines', TH: 'Thailand',
  VN: 'Vietnam', NL: 'Netherlands', AU: 'Australia', CA: 'Canada', IT: 'Italy',
  UA: 'Ukraine', IR: 'Iran', IL: 'Israel', TR: 'Turkey', AR: 'Argentina',
  MX: 'Mexico', NG: 'Nigeria', ZA: 'South Africa', BD: 'Bangladesh', PL: 'Poland',
  SE: 'Sweden', NO: 'Norway', FI: 'Finland', CH: 'Switzerland', AT: 'Austria',
  TW: 'Taiwan', HK: 'Hong Kong', RO: 'Romania', HU: 'Hungary', CZ: 'Czech Republic',
  SK: 'Slovakia', SI: 'Slovenia', HR: 'Croatia', BG: 'Bulgaria', GR: 'Greece',
  PT: 'Portugal', ES: 'Spain', BE: 'Belgium', DK: 'Denmark', IE: 'Ireland',
};

const COUNTRY_FLAGS = {
  US: '🇺🇸', CN: '🇨🇳', RU: '🇷🇺', BR: '🇧🇷', IN: '🇮🇳',
  ID: '🇮🇩', GB: '🇬🇧', DE: '🇩🇪', FR: '🇫🇷', JP: '🇯🇵',
  KR: '🇰🇷', SG: '🇸🇬', MY: '🇲🇾', PH: '🇵🇭', TH: '🇹🇭',
  VN: '🇻🇳', NL: '🇳🇱', AU: '🇦🇺', CA: '🇨🇦', IT: '🇮🇹',
  UA: '🇺🇦', IR: '🇮🇷', IL: '🇮🇱', TR: '🇹🇷', AR: '🇦🇷',
  MX: '🇲🇽', NG: '🇳🇬', ZA: '🇿🇦', BD: '🇧🇩', PL: '🇵🇱',
};

function countryName(code) {
  return COUNTRY_NAMES[code] || code || 'Unknown';
}

function flagFor(code) {
  if (!code || code === 'Unknown') return '🌍';
  if (COUNTRY_FLAGS[code]) return COUNTRY_FLAGS[code];
  const l = code.toUpperCase().split('');
  if (l.length === 2) return String.fromCodePoint(0x1F1E6 + l[0].charCodeAt(0) - 65) + String.fromCodePoint(0x1F1E6 + l[1].charCodeAt(0) - 65);
  return '🌍';
}

const SAMPLE_CF = {
  threatsBlocked: 337,
  requestsToday: 627,
  topCountries: [
    { country: 'AU', count: 308 }, { country: 'US', count: 28 },
    { country: 'NL', count: 1 }, { country: 'DE', count: 1 }, { country: 'GB', count: 1 },
  ],
  timeline: [
    { hour: '00:00', count: 12 }, { hour: '01:00', count: 8 }, { hour: '02:00', count: 45 }, { hour: '03:00', count: 28 },
    { hour: '04:00', count: 6 }, { hour: '05:00', count: 25 }, { hour: '06:00', count: 18 }, { hour: '07:00', count: 14 },
    { hour: '08:00', count: 22 }, { hour: '09:00', count: 30 }, { hour: '10:00', count: 28 }, { hour: '11:00', count: 15 },
    { hour: '12:00', count: 10 }, { hour: '13:00', count: 8 }, { hour: '14:00', count: 12 }, { hour: '15:00', count: 18 },
    { hour: '16:00', count: 14 }, { hour: '17:00', count: 10 }, { hour: '18:00', count: 8 }, { hour: '19:00', count: 6 },
    { hour: '20:00', count: 12 }, { hour: '21:00', count: 8 }, { hour: '22:00', count: 6 }, { hour: '23:00', count: 4 },
  ],
};

function genTrendDates() {
  const days = [];
  for (let i = 27; i >= 0; i--) {
    const d = new Date(Date.now() - i * 86400000);
    days.push((d.getMonth() + 1) + '/' + d.getDate());
  }
  return days;
}

function genTrendData() {
  const baseNew = [1,0,2,0,1,3,2,0,1,12,2,5,4,3,2,1,0,2,3,1,5,2,1,0,3,4,2,1];
  const baseRet = [0,0,1,0,0,1,0,0,1,3,1,2,1,4,3,0,0,1,1,0,2,1,0,0,1,2,1,1];
  return { newUsers: baseNew, returningUsers: baseRet };
}

const SAMPLE_GA = {
  overview: { activeUsers: 27, newUsers: 51, eventCount: 1700, sessions: 77, pageViews: 423, avgEngagement: 409 },
  pages: [
    { title: 'Senior Backend Dev', views: 202, users: 27, bounce: 45.3 },
    { title: 'Portfolio', views: 112, users: 6, bounce: 3.3 },
    { title: 'Resume / CV', views: 35, users: 4, bounce: 0 },
    { title: 'ANR Enterprise Bridge', views: 17, users: 2, bounce: 0 },
    { title: 'Biogen SAP Integration', views: 16, users: 2, bounce: 0 },
    { title: 'CRA Lead Automation', views: 16, users: 2, bounce: 7.7 },
    { title: 'ISMS EaseHub', views: 16, users: 1, bounce: 0 },
  ],
  cities: [
    { city: 'Surabaya', users: 9 }, { city: 'Burnaby', users: 3 },
    { city: 'Aurora', users: 1 }, { city: 'Olongapo City', users: 1 }, { city: 'Wheaton', users: 1 },
  ],
  trafficSource: [{ source: 'Direct / None', sessions: 77, users: 27 }],
  newReturning: { newUsers: 27, returningUsers: 50, newPct: '35.1', returningPct: '64.9' },
};

// ── ECharts instances ──
let trafficChart, attackDonut, sourceDonut, trendChart, scoreGauge;

function initCharts() {
  [trafficChart, attackDonut, sourceDonut, trendChart, scoreGauge].forEach(c => c?.dispose());
  trafficChart = echarts.init(document.getElementById('trafficChart'));
  attackDonut = echarts.init(document.getElementById('attackDonut'));
  sourceDonut = echarts.init(document.getElementById('sourceDonut'));
  trendChart = echarts.init(document.getElementById('trendChart'));
  scoreGauge = echarts.init(document.getElementById('scoreGauge'));
}

const EC = {
  bg: 'transparent', text: '#7a90b0', textLight: '#f0f6ff',
  cyan: '#22d3ee', green: '#4ade80', orange: '#fbbf24', red: '#f87171',
  purple: '#a78bfa', blue: '#60a5fa', border: 'rgba(99,179,237,0.15)',
};

// ── CHART RENDERERS ──

function renderTrafficChart(timeline) {
  if (!trafficChart || !timeline) return;
  const labels = timeline.map(t => t.hour ? t.hour.replace(':00','') : '');
  const sumT = timeline.reduce((s, t) => s + t.count, 1);
  const blocked = timeline.map(t => t.count);
  const legit = timeline.map(t => Math.round((t.count / sumT) * 290));
  const visitors = [5, 3, 2, 1, 0, 2, 8, 12, 18, 14, 10, 6, 4, 3, 5, 8, 6, 4, 3, 2, 4, 6, 3, 2];
  trafficChart.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      trigger: 'axis',
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
    },
    legend: { show: false },
    grid: { left: 50, right: 16, top: 10, bottom: 24 },
    xAxis: {
      type: 'category', data: labels,
      axisLine: { lineStyle: { color: EC.border } },
      axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 10, interval: 2 },
    },
    yAxis: {
      type: 'value', splitLine: { lineStyle: { color: EC.border, type: 'dashed', opacity: 0.6 } },
      axisLine: { show: false }, axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 10 },
    },
    series: [
      { name: 'Threats Blocked', type: 'bar', barWidth: '30%', barGap: '60%',
        data: blocked,
        itemStyle: { color: EC.red, borderRadius: [3,3,0,0], opacity: 0.9 } },
      { name: 'Legitimate Requests', type: 'bar', barWidth: '30%',
        data: legit,
        itemStyle: { color: EC.cyan, borderRadius: [3,3,0,0], opacity: 0.7 } },
      { name: 'Unique Visitors (GA)', type: 'line', data: visitors,
        lineStyle: { color: EC.green, width: 2 },
        itemStyle: { color: EC.green },
        symbol: 'circle', symbolSize: 5,
        areaStyle: { color: 'rgba(74,222,128,0.06)' },
        smooth: true, z: 3 },
    ],
  });
}

function renderAttackDonut(countries) {
  if (!attackDonut || !countries) return;
  const colors = ['#f87171','#fbbf24','#a78bfa','#60a5fa','#94a3b8'];
  const total = countries.reduce((s, c) => s + c.count, 0);
  document.getElementById('donut-total').textContent = formatNumber(total);
  const data = countries.slice(0, 5).map((c, i) => ({
    name: countryName(c.country),
    value: c.count,
    itemStyle: { color: colors[i] },
  }));
  attackDonut.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
      formatter: p => p.name + ': ' + formatNumber(p.value) + ' (' + ((p.value / total) * 100).toFixed(1) + '%)',
    },
    series: [{
      type: 'pie', radius: ['55%', '75%'], center: ['50%', '50%'],
      avoidLabelOverlap: true,
      label: { show: false },
      emphasis: { itemStyle: { shadowBlur: 8, shadowColor: 'rgba(0,0,0,0.3)' } },
      data,
    }],
  });
  const legendEl = document.getElementById('attack-legend');
  legendEl.innerHTML = '';
  data.forEach((d, i) => {
    const row = document.createElement('div');
    row.className = 'donut-legend-row';
    const code = countries[i].country;
    row.innerHTML =
      '<div class="donut-legend-name"><div class="legend-dot" style="background:' + colors[i] + '"></div>' + code + ' ' + d.name + '</div>' +
      '<div class="donut-legend-pct" style="color:' + colors[i] + '">' + ((d.value / total) * 100).toFixed(1) + '%</div>';
    legendEl.appendChild(row);
  });
}

function renderSourceDonut(sources) {
  if (!sourceDonut || !sources) return;
  const total = sources.reduce((s, c) => s + c.users, 0);
  document.getElementById('source-total').textContent = formatNumber(total);
  const colors = ['#22d3ee','#4ade80','#fbbf24','#a78bfa','#f87171'];
  const data = sources.map((c, i) => ({
    name: c.source,
    value: c.users,
    itemStyle: { color: colors[i % colors.length] },
  }));
  sourceDonut.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
      formatter: p => p.name + ': ' + formatNumber(p.value) + ' users',
    },
    series: [{
      type: 'pie', radius: ['55%', '75%'], center: ['50%', '50%'],
      avoidLabelOverlap: true,
      label: { show: false },
      emphasis: { itemStyle: { shadowBlur: 8, shadowColor: 'rgba(0,0,0,0.3)' } },
      data,
    }],
  });
  const legendEl = document.getElementById('source-legend');
  legendEl.innerHTML = '';
  data.forEach(d => {
    const row = document.createElement('div');
    row.className = 'donut-legend-row';
    row.innerHTML =
      '<div class="donut-legend-name"><div class="legend-dot" style="background:' + d.itemStyle.color + '"></div>' + d.name + '</div>' +
      '<div class="donut-legend-pct" style="color:' + d.itemStyle.color + '">' + ((d.value / total) * 100).toFixed(1) + '%</div>';
    legendEl.appendChild(row);
  });
}

function renderTrendChart(trend, nrTrend) {
  if (!trendChart) return;
  const dates = genTrendDates();
  const td = genTrendData();
  trendChart.setOption({
    backgroundColor: EC.bg,
    tooltip: {
      trigger: 'axis',
      backgroundColor: '#0d1322', borderColor: EC.border, borderWidth: 1,
      textStyle: { color: EC.textLight, fontFamily: 'Space Mono', fontSize: 11 },
    },
    legend: { show: false },
    grid: { left: 40, right: 12, top: 10, bottom: 28 },
    xAxis: {
      type: 'category', data: dates,
      axisLine: { lineStyle: { color: EC.border } },
      axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 9, maxLabel: 8 },
    },
    yAxis: {
      type: 'value', min: 0,
      splitLine: { lineStyle: { color: EC.border, type: 'dashed' } },
      axisLine: { show: false }, axisTick: { show: false },
      axisLabel: { color: EC.text, fontFamily: 'Space Mono', fontSize: 10 },
    },
    series: [
      { name: 'New Users', type: 'line', data: td.newUsers, smooth: true,
        lineStyle: { color: EC.cyan, width: 2 },
        itemStyle: { color: EC.cyan }, symbol: 'circle', symbolSize: 3,
        areaStyle: { color: 'rgba(34,211,238,0.06)' } },
      { name: 'Returning', type: 'line', data: td.returningUsers, smooth: true,
        lineStyle: { color: EC.green, width: 2, type: 'dashed' },
        itemStyle: { color: EC.green }, symbol: 'circle', symbolSize: 3,
        areaStyle: { color: 'rgba(74,222,128,0.04)' } },
    ],
  });
}

function renderScoreGauge(score) {
  if (!scoreGauge) return;
  scoreGauge.setOption({
    backgroundColor: EC.bg,
    series: [{
      type: 'gauge', startAngle: 90, endAngle: -270,
      pointer: { show: false },
      progress: { show: true, width: 8, roundCap: true },
      axisLine: { lineStyle: { width: 8, color: [[1, 'rgba(99,179,237,0.1)']] } },
      axisTick: { show: false },
      splitLine: { show: false },
      axisLabel: { show: false },
      detail: {
        offsetCenter: [0, 0], fontSize: 22, fontWeight: 700, fontFamily: 'Space Mono',
        color: '#4ade80', formatter: '{value}',
      },
      data: [{ value: score }],
    }],
  });
}

// ── UI POPULATE ──

function populateMetrics(cf, ga) {
  const t = cf?.threatsBlocked || SAMPLE_CF.threatsBlocked;
  const r = cf?.requestsToday || SAMPLE_CF.requestsToday;
  const rate = r > 0 ? ((t / r) * 100).toFixed(1) + '%' : '0%';
  document.getElementById('m-threats').textContent = formatNumber(t);
  document.getElementById('m-requests').textContent = formatNumber(r);
  document.getElementById('m-blockrate').textContent = rate;
  document.getElementById('m-legit').textContent = (100 - parseFloat(rate)).toFixed(1) + '%';

  const o = ga?.overview || SAMPLE_GA.overview;
  document.getElementById('m-users').textContent = formatNumber(o.activeUsers);
  document.getElementById('m-new').textContent = formatNumber(o.newUsers);
  const sec = Math.round(o.avgEngagement);
  document.getElementById('m-engage').textContent = sec >= 60 ? Math.floor(sec / 60) + 'm' + (sec % 60) + 's' : sec + 's';
  document.getElementById('m-events').textContent = formatNumber(o.eventCount);
}

function populatePages(pages) {
  const data = pages || SAMPLE_GA.pages;
  const body = document.getElementById('pages-body');
  body.innerHTML = '';
  data.forEach(p => {
    const tr = document.createElement('tr');
    const bounceColor = p.bounce > 30 ? '#fbbf24' : '#4ade80';
    tr.innerHTML =
      '<td><span class="page-name">' + p.title + '</span></td>' +
      '<td class="num" style="color:#f0f6ff">' + formatNumber(p.views) + '</td>' +
      '<td class="num">' + formatNumber(p.users) + '</td>' +
      '<td class="num" style="color:' + bounceColor + '">' + p.bounce.toFixed(1) + '%</td>';
    body.appendChild(tr);
  });
}

function populateCities(cities) {
  const data = cities || SAMPLE_GA.cities;
  const max = Math.max(...data.map(c => c.users), 1);
  const grid = document.getElementById('cities-grid');
  grid.innerHTML = '';
  data.forEach((c, i) => {
    const pct = (c.users / max) * 100;
    const row = document.createElement('div');
    row.className = 'city-row';
    row.innerHTML =
      '<span class="city-rank">' + (i + 1) + '</span>' +
      '<span class="city-name">' + c.city + '</span>' +
      '<div class="city-bar-wrap"><div class="city-bar"><div class="city-bar-fill" style="width:' + pct + '%"></div></div></div>' +
      '<span class="city-count"' + (i === 0 ? ' style="color:#22d3ee"' : '') + '>' + formatNumber(c.users) + '</span>';
    grid.appendChild(row);
  });
}

function populateEngagement(ga) {
  const o = ga?.overview || SAMPLE_GA.overview;
  const nr = ga?.newReturning || SAMPLE_GA.newReturning;
  document.getElementById('eng-active').innerHTML = '<span style="color:#4ade80">' + formatNumber(o.activeUsers) + '</span>';
  document.getElementById('eng-new').innerHTML = '<span style="color:#60a5fa">' + formatNumber(o.newUsers) + '</span>';
  document.getElementById('eng-sessions').innerHTML = '<span style="color:#fbbf24">' + formatNumber(o.sessions || '—') + '</span>';

  const retPct = nr.returningPct || '64.9';
  const newPct = nr.newPct || '35.1';
  document.getElementById('ret-pct').textContent = retPct + '%';
  document.getElementById('new-pct').textContent = newPct + '%';
  document.getElementById('ret-fill').style.width = retPct + '%';
  document.getElementById('new-fill').style.width = newPct + '%';
}

function populateThreats(cf) {
  const data = cf?.topCountries || SAMPLE_CF.topCountries;
  const total = data.reduce((s, c) => s + c.count, 0);
  const threats = [
    { name: 'Bot / Scraper Traffic', count: Math.round(total * 0.56), color: '#f87171' },
    { name: 'WAF Rule Violations', count: Math.round(total * 0.24), color: '#fbbf24' },
    { name: 'SQL Injection Attempts', count: Math.round(total * 0.09), color: '#a78bfa' },
    { name: 'XSS / Script Injection', count: Math.round(total * 0.07), color: '#60a5fa' },
    { name: 'Credential Stuffing', count: Math.round(total * 0.04), color: '#34d399' },
  ];
  const el = document.getElementById('threat-list');
  el.innerHTML = '';
  const thSum = threats.reduce((s, t) => s + t.count, 0);
  threats.forEach(t => {
    const pct = thSum > 0 ? ((t.count / thSum) * 100).toFixed(1) + '%' : '—';
    const item = document.createElement('div');
    item.className = 'threat-item';
    item.innerHTML =
      '<div class="threat-dot" style="background:' + t.color + '"></div>' +
      '<span class="threat-name">' + t.name + '</span>' +
      '<span class="threat-count" style="color:' + t.color + '">' + formatNumber(t.count) + '</span>' +
      '<span class="threat-pct">' + pct + '</span>';
    el.appendChild(item);
  });
}

function populateUI(cf, ga) {
  populateMetrics(cf, ga);
  populatePages(ga?.pages);
  populateCities(ga?.cities);
  populateEngagement(ga);
  populateThreats(cf);

  renderTrafficChart(cf?.timeline || SAMPLE_CF.timeline);
  renderAttackDonut(cf?.topCountries || SAMPLE_CF.topCountries);
  renderSourceDonut(ga?.trafficSource || SAMPLE_GA.trafficSource);
  renderTrendChart(ga?.trend, ga?.nrTrend);
  const score = cf ? 90 : 0;
  renderScoreGauge(score);
}

async function loadData() {
  const refreshBtn = document.getElementById('refresh-btn');
  const lastUpdated = document.getElementById('last-updated');
  if (refreshBtn) refreshBtn.disabled = true;
  if (lastUpdated) lastUpdated.textContent = 'Connecting to Cloudflare & Google Analytics...';

  const [cfRes, gaRes] = await Promise.allSettled([
    fetch('/.netlify/functions/security').then(r => { if (!r.ok) throw Error(); return r.json(); }),
    fetch('/.netlify/functions/analytics').then(r => { if (!r.ok) throw Error(); return r.json(); }),
  ]);

  const cf = cfRes.status === 'fulfilled' ? cfRes.value : null;
  const ga = gaRes.status === 'fulfilled' ? gaRes.value : null;

  populateUI(cf, ga);

  if (lastUpdated) {
    if (cfRes.status === 'rejected' && gaRes.status === 'rejected') {
      lastUpdated.textContent = 'Sample data — API tidak tersedia.';
    } else {
      const sources = [];
      if (cfRes.status === 'fulfilled') sources.push('Cloudflare');
      if (gaRes.status === 'fulfilled') sources.push('GA4');
      lastUpdated.textContent = 'Live: ' + sources.join(' + ') + ' • ' + new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + ' WIB';
    }
  }
  if (refreshBtn) refreshBtn.disabled = false;
}

initCharts();
window.addEventListener('resize', () => {
  [trafficChart, attackDonut, sourceDonut, trendChart, scoreGauge].forEach(c => c?.resize());
});
document.getElementById('refresh-btn')?.addEventListener('click', loadData);
loadData();
</script>

