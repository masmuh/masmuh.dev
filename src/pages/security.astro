---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Security Dashboard — Mas Muhammad"
  description="Real-time security analytics dashboard for masmuh.web.id powered by Cloudflare Analytics"
>
  <nav>
    <a href="/" class="nav-logo">Mas<span>.</span>ID</a>
    <ul class="nav-links">
      <li><a href="/">About</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/resume">CV</a></li>
      <li><a href="/security" class="active-link">Security</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <div class="nav-right">
      <div class="nav-status">
        <span class="status-dot"></span>
        LIVE
      </div>
      <button class="theme-toggle" id="themeToggle" title="Toggle theme">
        <span class="theme-icon-dark">☀</span>
        <span class="theme-icon-light">☾</span>
      </button>
    </div>
  </nav>

  <main class="security-page">
    <section class="security-hero">
      <div class="section-header">
        <span class="section-num">[SECURITY]</span>
        <h1 class="section-title">Dashboard</h1>
        <div class="section-line"></div>
      </div>

      <div class="security-intro">
        <p class="intro-text">
          This dashboard displays <strong>real-time security analytics</strong> from
          <strong>Cloudflare</strong> for <code>masmuh.web.id</code>.
          Cloudflare automatically filters and blocks threats before they reach the
          server, including DDoS attacks, SQL Injection, cross-site scripting (XSS),
          credential stuffing, and malicious bots.
        </p>
        <div class="intro-details">
          <div class="intro-item">
            <span class="intro-icon">🛡️</span>
            <div>
              <strong>Web Application Firewall (WAF)</strong>
              <p>Cloudflare WAF inspects every incoming request and blocks common attack patterns using OWASP rules and real-time signature updates.</p>
            </div>
          </div>
          <div class="intro-item">
            <span class="intro-icon">🤖</span>
            <div>
              <strong>Bot Management</strong>
              <p>Cloudflare identifies and classifies bot traffic through behavioral analysis, fingerprinting, and machine learning — distinguishing legitimate bots (search engines) from malicious ones (scrapers, attackers).</p>
            </div>
          </div>
          <div class="intro-item">
            <span class="intro-icon">📊</span>
            <div>
              <strong>Analytics & Monitoring</strong>
              <p>Data is sourced directly from the Cloudflare GraphQL Analytics API, providing accurate, real-time insight into threats blocked at the edge.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="security-grid">
        <div class="stat-card">
          <div class="stat-icon">🛡️</div>
          <div class="stat-value" id="stat-threats">—</div>
          <div class="stat-label">Threats Blocked (24h)</div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">📊</div>
          <div class="stat-value" id="stat-requests">—</div>
          <div class="stat-label">Total Requests (24h)</div>
        </div>

        <div class="stat-card">
          <div class="stat-icon">🌍</div>
          <div class="stat-value" id="stat-top-country">—</div>
          <div class="stat-label" id="stat-top-label">Top Attacker</div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">⚠️</div>
          <div class="stat-value" id="stat-rate">—</div>
          <div class="stat-label">Block Rate</div>
        </div>
      </div>
    </section>

    <section class="timeline-section">
      <div class="section-header">
        <span class="section-num">[ANALYTICS]</span>
        <h2 class="section-title">Attack Timeline</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="timeline-chart">
        <div class="chart-bars" id="timeline-bars">
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
          <div class="chart-bar" style="--height: 5%;"><span class="bar-tooltip">—</span></div>
        </div>
        <div class="chart-labels" id="timeline-labels">
          <span>00:00</span><span>02:00</span><span>04:00</span><span>06:00</span>
          <span>08:00</span><span>10:00</span><span>12:00</span><span>14:00</span>
          <span>16:00</span><span>18:00</span><span>20:00</span><span>22:00</span>
        </div>
      </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
          <div class="chart-bar chart-bar--loading" style="--height: 10%;">
            <span class="bar-tooltip">—</span>
          </div>
        </div>
        <div class="chart-labels" id="timeline-labels"></div>
      </div>
    </section>

    <section class="protected-section">
      <div class="section-header">
        <span class="section-num">[PROTECTION]</span>
        <h2 class="section-title">Cloudflare Protections</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="protected-grid">
        <div class="protected-item">
          <span class="protected-icon">🛡️</span>
          <strong>WAF</strong>
          <p>Web Application Firewall blocks OWASP Top 10 attacks including SQLi, XSS, and path traversal at the edge before they reach your server.</p>
        </div>
        <div class="protected-item">
          <span class="protected-icon">🌊</span>
          <strong>DDoS Mitigation</strong>
          <p>Cloudflare automatically detects and mitigates volumetric DDoS attacks across L3/L4/L7, scrubbing malicious traffic in real-time.</p>
        </div>
        <div class="protected-item">
          <span class="protected-icon">🤖</span>
          <strong>Bot Management</strong>
          <p>Machine learning-based bot detection classifies traffic as automated or human, blocking malicious scrapers and credential stuffers.</p>
        </div>
        <div class="protected-item">
          <span class="protected-icon">🔒</span>
          <strong>SSL/TLS</strong>
          <p>End-to-end encryption with automatic certificate management, HSTS preloading, and forced HTTPS for all visitor connections.</p>
        </div>
      </div>
    </section>

    <section class="countries-section">
      <div class="section-header">
        <span class="section-num">[SOURCE]</span>
        <h2 class="section-title">Top Attacking Countries</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="countries-list" id="countries-list">
        <div class="country-item">
          <span class="country-rank">—</span>
          <span class="country-flag">—</span>
          <span class="country-name">Waiting for data...</span>
          <span class="country-count">—</span>
        </div>
      </div>
    </section>

    <section class="refresh-section">
      <button class="btn-secondary refresh-btn" id="refresh-btn">
        ↻ Refresh Data
      </button>
      <p class="last-updated" id="last-updated">Loading Cloudflare analytics...</p>
    </section>
  </main>

  <footer>
    <div class="footer-left">
      <span>Mas</span>Muhammad © 2026
    </div>
    <div class="footer-center">Senior Backend Engineer</div>
    <div class="footer-right">
      <a href="/"><span>Home</span></a>
      <span>·</span>
      <a href="/resume"><span>CV</span></a>
      <span>·</span>
      <a href="/security"><span>Security</span></a>
    </div>
  </footer>
</Layout>

<script>
const formatNumber = n => n.toLocaleString();

const COUNTRY_NAMES = {
  US: 'United States', CN: 'China', RU: 'Russia', BR: 'Brazil', IN: 'India',
  ID: 'Indonesia', GB: 'United Kingdom', DE: 'Germany', FR: 'France', JP: 'Japan',
  KR: 'South Korea', SG: 'Singapore', MY: 'Malaysia', PH: 'Philippines', TH: 'Thailand',
  VN: 'Vietnam', NL: 'Netherlands', AU: 'Australia', CA: 'Canada', IT: 'Italy',
  UA: 'Ukraine', IR: 'Iran', IL: 'Israel', TR: 'Turkey', AR: 'Argentina',
  MX: 'Mexico', NG: 'Nigeria', ZA: 'South Africa', BD: 'Bangladesh', PL: 'Poland',
  SE: 'Sweden', NO: 'Norway', FI: 'Finland', CH: 'Switzerland', AT: 'Austria',
  TW: 'Taiwan', HK: 'Hong Kong', RO: 'Romania', HU: 'Hungary', CZ: 'Czech Republic',
  SK: 'Slovakia', SI: 'Slovenia', HR: 'Croatia', BG: 'Bulgaria', GR: 'Greece',
  PT: 'Portugal', ES: 'Spain', BE: 'Belgium', DK: 'Denmark', IE: 'Ireland',
};

const COUNTRY_FLAGS = {
  US: '🇺🇸', CN: '🇨🇳', RU: '🇷🇺', BR: '🇧🇷', IN: '🇮🇳',
  ID: '🇮🇩', GB: '🇬🇧', DE: '🇩🇪', FR: '🇫🇷', JP: '🇯🇵',
  KR: '🇰🇷', SG: '🇸🇬', MY: '🇲🇾', PH: '🇵🇭', TH: '🇹🇭',
  VN: '🇻🇳', NL: '🇳🇱', AU: '🇦🇺', CA: '🇨🇦', IT: '🇮🇹',
  UA: '🇺🇦', IR: '🇮🇷', IL: '🇮🇱', TR: '🇹🇷', AR: '🇦🇷',
  MX: '🇲🇽', NG: '🇳🇬', ZA: '🇿🇦', BD: '🇧🇩', PL: '🇵🇱',
  SE: '🇸🇪', NO: '🇳🇴', FI: '🇫🇮', CH: '🇨🇭', AT: '🇦🇹',
  TW: '🇹🇼', HK: '🇭🇰', RO: '🇷🇴', HU: '🇭🇺', CZ: '🇨🇿',
  SK: '🇸🇰', SI: '🇸🇮', HR: '🇭🇷', BG: '🇧🇬', GR: '🇬🇷',
  PT: '🇵🇹', ES: '🇪🇸', BE: '🇧🇪', DK: '🇩🇰', IE: '🇮🇪',
};

function countryName(code) {
  return COUNTRY_NAMES[code] || code || 'Unknown';
}

function flagFor(code) {
  if (!code || code === 'Unknown') return '🌍';
  if (COUNTRY_FLAGS[code]) return COUNTRY_FLAGS[code];
  const l = code.toUpperCase().split('');
  if (l.length === 2) return String.fromCodePoint(0x1F1E6 + l[0].charCodeAt(0) - 65) + String.fromCodePoint(0x1F1E6 + l[1].charCodeAt(0) - 65);
  return '🌍';
}

// Sample data for local dev fallback
const SAMPLE = {
  threatsBlocked: 12847,
  requestsToday: 4291,
  timeline: [
    { hour: '00:00', count: 42 }, { hour: '01:00', count: 38 },
    { hour: '02:00', count: 25 }, { hour: '03:00', count: 18 },
    { hour: '04:00', count: 22 }, { hour: '05:00', count: 31 },
    { hour: '06:00', count: 45 }, { hour: '07:00', count: 67 },
    { hour: '08:00', count: 89 }, { hour: '09:00', count: 120 },
    { hour: '10:00', count: 145 }, { hour: '11:00', count: 132 },
    { hour: '12:00', count: 98 }, { hour: '13:00', count: 87 },
    { hour: '14:00', count: 112 }, { hour: '15:00', count: 95 },
    { hour: '16:00', count: 78 }, { hour: '17:00', count: 65 },
    { hour: '18:00', count: 54 }, { hour: '19:00', count: 48 },
    { hour: '20:00', count: 52 }, { hour: '21:00', count: 43 },
    { hour: '22:00', count: 38 }, { hour: '23:00', count: 29 },
  ],
  topCountries: [
    { country: 'ID', count: 4291 }, { country: 'CN', count: 2156 },
    { country: 'RU', count: 1843 }, { country: 'US', count: 1247 },
    { country: 'BR', count: 956 },
  ],
};

function populateUI(data) {
  document.getElementById('stat-threats').textContent = formatNumber(data.threatsBlocked);
  document.getElementById('stat-requests').textContent = formatNumber(data.requestsToday);

  const rate = data.requestsToday > 0
    ? ((data.threatsBlocked / data.requestsToday) * 100).toFixed(1) + '%'
    : '0%';
  document.getElementById('stat-rate').textContent = rate;

  const top = data.topCountries?.[0];
  const topEl = document.getElementById('stat-top-country');
  const topLabel = document.getElementById('stat-top-label');
  if (top && top.country) {
    topEl.textContent = flagFor(top.country);
    topLabel.textContent = countryName(top.country);
  }

  // Timeline
  const barsEl = document.getElementById('timeline-bars');
  const labelsEl = document.getElementById('timeline-labels');
  if (data.timeline && barsEl) {
    const maxC = Math.max(...data.timeline.map(t => t.count), 1);
    barsEl.innerHTML = '';
    labelsEl.innerHTML = '';
    for (const t of data.timeline) {
      const pct = (t.count / maxC) * 85 + 5;
      const bar = document.createElement('div');
      bar.className = 'chart-bar';
      bar.style.setProperty('--height', pct + '%');
      bar.innerHTML = `<span class="bar-tooltip">${formatNumber(t.count)}</span>`;
      barsEl.appendChild(bar);
      const lbl = document.createElement('span');
      lbl.textContent = t.hour;
      labelsEl.appendChild(lbl);
    }
  }

  // Countries
  const cEl = document.getElementById('countries-list');
  if (data.topCountries && cEl) {
    cEl.innerHTML = '';
    data.topCountries.slice(0, 5).forEach((c, i) => {
      const item = document.createElement('div');
      item.className = 'country-item';
      item.innerHTML = `
        <span class="country-rank">#${i + 1}</span>
        <span class="country-flag">${flagFor(c.country)}</span>
        <span class="country-name">${countryName(c.country)}</span>
        <span class="country-count">${formatNumber(c.count)}</span>`;
      cEl.appendChild(item);
    });
  }
}

async function loadData() {
  const refreshBtn = document.getElementById('refresh-btn');
  const lastUpdated = document.getElementById('last-updated');
  if (refreshBtn) refreshBtn.disabled = true;
  if (lastUpdated) lastUpdated.textContent = 'Connecting to Cloudflare...';

  try {
    const res = await fetch('/.netlify/functions/security');
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    populateUI(data);
    if (lastUpdated) lastUpdated.textContent = 'Last updated: ' + new Date().toLocaleTimeString();
  } catch {
    populateUI(SAMPLE);
    if (lastUpdated) lastUpdated.textContent = 'Sample data — connect to Netlify for live updates.';
  } finally {
    if (refreshBtn) refreshBtn.disabled = false;
  }
}

document.getElementById('refresh-btn')?.addEventListener('click', loadData);
loadData();
</script>

<style>
  .security-page {
    padding-top: 100px;
  }

  .security-hero {
    padding: 60px;
  }

  .security-intro {
    margin-bottom: 60px;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 32px;
  }

  .intro-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--white);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .intro-text strong {
    color: var(--cyan);
  }

  .intro-text code {
    font-family: var(--font-mono);
    color: var(--green);
    font-size: 12px;
  }

  .intro-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .intro-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
  }

  .intro-icon {
    font-size: 24px;
    flex-shrink: 0;
  }

  .intro-item div {
    flex: 1;
  }

  .intro-item strong {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--cyan);
    text-transform: uppercase;
    display: block;
    margin-bottom: 6px;
  }

  .intro-item p {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .security-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--cyan);
    opacity: 0.5;
  }

  .stat-card:hover {
    border-color: var(--border-bright);
    transform: translateY(-4px);
  }

  .stat-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -2px;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  .stat-trend {
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: 12px;
    padding: 4px 10px;
    display: inline-block;
    clip-path: polygon(4px 0%, 100% 0%, calc(100% - 4px) 100%, 0% 100%);
  }

  .stat-trend.positive {
    background: rgba(0, 255, 157, 0.1);
    color: var(--green);
    border: 1px solid rgba(0, 255, 157, 0.3);
  }

  .stat-trend.negative {
    background: rgba(255, 107, 53, 0.1);
    color: var(--orange);
    border: 1px solid rgba(255, 107, 53, 0.3);
  }

  .stat-trend.neutral {
    background: rgba(0, 200, 255, 0.1);
    color: var(--cyan);
    border: 1px solid var(--border-bright);
  }

  .threat-blocked .stat-value { color: var(--cyan); }
  .bot-traffic .stat-value { color: var(--orange); }
  .top-attacker .stat-value { font-size: 36px; }

  /* Timeline Section */
  .timeline-section {
    padding: 60px;
  }

  .timeline-chart {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 40px;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 200px;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .chart-bar {
    flex: 1;
    max-width: 80px;
    height: var(--height);
    background: linear-gradient(to top, var(--cyan), var(--green));
    position: relative;
    transition: all 0.3s;
    cursor: pointer;
  }

  .chart-bar:hover {
    opacity: 0.8;
    transform: scaleY(1.02);
  }

  .chart-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 200, 255, 0.3), transparent);
  }

  .bar-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    border: 1px solid var(--border-bright);
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
    pointer-events: none;
  }

  .chart-bar:hover .bar-tooltip {
    opacity: 1;
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  /* Breakdown Section */
  .breakdown-section {
    padding: 60px;
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .breakdown-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px;
  }

  .breakdown-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .breakdown-icon {
    font-size: 20px;
  }

  .breakdown-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--muted);
    text-transform: uppercase;
    flex: 1;
  }

  .breakdown-value {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--white);
  }

  .breakdown-bar {
    height: 8px;
    background: var(--bg2);
    border-radius: 4px;
    overflow: hidden;
  }

  .breakdown-fill {
    height: 100%;
    width: var(--width);
    background: linear-gradient(90deg, var(--cyan), var(--green));
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .breakdown-percent {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    margin-top: 8px;
    text-align: right;
  }

  /* Countries Section */
  .countries-section {
    padding: 60px;
  }

  .countries-list {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .country-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 28px;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
  }

  .country-item:last-child {
    border-bottom: none;
  }

  .country-item:hover {
    background: var(--cyan-glow);
  }

  .country-rank {
    font-family: var(--font-mono);
