---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout
  title="Uses — Mas Muhammad"
  description="Tools, software, and services I rely on daily as a backend engineer. No fluff — just what actually ships to production."
>
  <Nav variant="default" activePath="/uses" statusText="USES.TECH" />

  <main class="uses-page">
    <div class="wrap">
      <div class="page-header">
        <div class="page-tag">[ USES + SETUP ]</div>
        <h1 class="page-title">What I <span class="dim">Use</span></h1>
        <p class="page-subtitle">
          Tools, software, and services I rely on daily as a backend engineer.
          No fluff — just what actually ships to production.
        </p>
        <div class="page-meta">Last updated <span>May 2026</span></div>
      </div>

      <!-- HARDWARE -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ HARDWARE ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div class="uses-card uses-card-featured" style="--accent: #ffd166;">
            <span class="uses-emoji-lg">💻</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name"
                  >HP Laptop — AMD Ryzen 5, 32GB RAM</span
                >
                <span class="uses-tag uses-tag-cyan">Daily Driver</span>
              </div>
              <p class="uses-card-desc">
                No battery — essentially an accidental desktop. Tried replacing
                the battery multiple times, always dies anyway. Plugged in 24/7,
                goes nowhere, ships everywhere.
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">🖱️</span>
              <span class="uses-card-name">External Mouse</span>
              <span class="uses-tag uses-tag-cyan">Daily Driver</span>
            </div>
            <p class="uses-card-desc">
              Trackpad is a no from me. A simple external mouse makes everything
              faster and less frustrating.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">🎧</span>
              <span class="uses-card-name">Earphone × 10</span>
              <span class="uses-tag uses-tag-orange">Bulk Strategy</span>
            </div>
            <p class="uses-card-desc">
              Always buy the cheapest earphone — in bulk of 10. One breaks? Grab
              the next. No grief, no drama. Pure engineering efficiency.
              Currently on unit #3.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">🌬️</span>
              <span class="uses-card-name">USB Cooling Pad</span>
              <span class="uses-tag uses-tag-muted">Underrated</span>
            </div>
            <p class="uses-card-desc">
              A small fan that doubles as a laptop stand, powered via USB. Keeps
              the old machine cool under heavy workloads. Humble but essential.
            </p>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🌐</span>
              <span class="uses-card-name">IndiHome — 30–50 Mbps</span>
              <span class="uses-tag uses-tag-muted">Internet</span>
            </div>
            <p class="uses-card-desc">
              Classic Indonesian developer internet. Not the fastest, but
              reliable enough to push code, join calls, and run remote workloads
              without rage-quitting. Ada issue? WhatsApp CS aja — beres dalam
              hitungan jam. Hehehe.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">🪑</span>
              <span class="uses-card-name">Orange Chair + Black Desk</span>
              <span class="uses-tag uses-tag-muted">Remote Setup</span>
            </div>
            <p class="uses-card-desc">
              Nothing fancy — orange chair, black desk, and a Sanex standing fan
              working double shifts in the East Java heat. Ships code daily.
              That's all a backend engineer really needs.
            </p>
          </div>
        </div>
      </section>

      <!-- EDITORS & IDE -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ EDITORS & IDE ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--cyan);"
          >
            <span class="uses-emoji-lg">🚀</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name">Google Antigravity</span>
                <span class="uses-tag uses-tag-green">Favourite</span>
              </div>
              <p class="uses-card-desc">
                Agent-first IDE by Google. Not just an editor — it autonomously
                plans, executes, and verifies tasks across editor, terminal, and
                browser. Early adopter and loving it.
                <br><a href="https://antigravity.google" target="_blank" rel="noopener noreferrer" class="uses-link">antigravity.google ↗</a>
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: #a78bfa;">
            <div class="uses-card-top">
              <span class="uses-emoji">🔷</span>
              <span class="uses-card-name">Visual Studio 2026</span>
              <span class="uses-tag uses-tag-cyan">Daily Driver</span>
            </div>
            <p class="uses-card-desc">
              The classic for .NET development. Heavy but irreplaceable for
              enterprise C# and ERP work.
            </p>
          </div>
          <div class="uses-card" style="--accent: #a78bfa;">
            <div class="uses-card-top">
              <span class="uses-emoji">🐧</span>
              <span class="uses-card-name">WSL2 (Ubuntu)</span>
              <span class="uses-tag uses-tag-cyan">Daily Driver</span>
            </div>
            <p class="uses-card-desc">
              Linux environment inside Windows. Real bash, real tools, zero
              compromise.
            </p>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🐙</span>
              <span class="uses-card-name">SourceTree</span>
              <span class="uses-tag uses-tag-muted">Git GUI</span>
            </div>
            <p class="uses-card-desc">
              When I need to visualize branches and history. CLI for speed,
              SourceTree for clarity.
            </p>
          </div>
        </div>
      </section>

      <!-- BROWSER & EXTENSIONS -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ BROWSER & EXTENSIONS ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--cyan);"
          >
            <span class="uses-emoji-lg">🔵</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name">Microsoft Edge</span>
                <span class="uses-tag uses-tag-cyan">Primary Browser</span>
              </div>
              <p class="uses-card-desc">
                Main browser because of multi-workspace support — separate
                sessions for work, personal, and client projects without
                constant login switching. Underrated feature.
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🔑</span>
              <span class="uses-card-name">Proton Pass</span>
              <span class="uses-tag uses-tag-muted">Extension</span>
            </div>
            <p class="uses-card-desc">
              Password manager. Encrypted, private, and open-source. No excuses
              for weak passwords.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">🛡️</span>
              <span class="uses-card-name">AdGuard AdBlock</span>
              <span class="uses-tag uses-tag-muted">Extension</span>
            </div>
            <p class="uses-card-desc">
              Block ads, trackers, and noise. Cleaner web, faster browsing.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">⏱️</span>
              <span class="uses-card-name">Foculing Time Tracker</span>
              <span class="uses-tag uses-tag-orange">Built by Me</span>
            </div>
            <p class="uses-card-desc">
              A browser extension I built myself to track focused work sessions.
              Scratching my own itch — couldn't find one that worked exactly how
              I wanted.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--muted);">
            <div class="uses-card-top">
              <span class="uses-emoji">🟡</span>
              <span class="uses-card-name">Chrome</span>
              <span class="uses-tag uses-tag-muted">Rarely Used</span>
            </div>
            <p class="uses-card-desc">
              Installed, rarely opened. Mostly for cross-browser testing.
            </p>
          </div>
        </div>
      </section>

      <!-- DEV TOOLS -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ DEV TOOLS ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--green);"
          >
            <span class="uses-emoji-lg">🚀</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name">.NET (C#)</span>
                <span class="uses-tag uses-tag-green">Favourite</span>
              </div>
              <p class="uses-card-desc">
                11 years, from .NET Framework to .NET 10. Clean Architecture,
                CQRS, DDD, microservices — this isn't just a language, it's a
                career. Even wrote a book about it (<em>Mastering .NET 10</em>).
                <br><a href="https://www.amazon.com/dp/B0GGRTZ7JG" target="_blank" rel="noopener noreferrer" class="uses-link">amazon.com/dp/B0GGRTZ7JG ↗</a>
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">📮</span>
              <span class="uses-card-name">Postman</span>
              <span class="uses-tag uses-tag-cyan">Daily Driver</span>
            </div>
            <p class="uses-card-desc">
              API testing and documentation. Every endpoint gets tested here
              before it goes to production.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">🤖</span>
              <span class="uses-card-name">OpenCode</span>
              <span class="uses-tag uses-tag-muted">AI Coding</span>
            </div>
            <p class="uses-card-desc">
              Open-source alternative to Claude Code. I subscribe to OpenCode Go
              for cloud models, also run frontier AI models locally via Ollama.
              Free, private, powerful. The subject of my latest article.
              <br><a href="https://opencode.ai" target="_blank" rel="noopener noreferrer" class="uses-link">opencode.ai ↗</a>
            </p>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🦫</span>
              <span class="uses-card-name">DBeaver</span>
              <span class="uses-tag uses-tag-muted">DB Browser</span>
            </div>
            <p class="uses-card-desc">
              Universal database browser. One tool for SQL Server, PostgreSQL,
              MySQL, and more.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">🍃</span>
              <span class="uses-card-name">MongoDB Compass</span>
              <span class="uses-tag uses-tag-muted">DB Browser</span>
            </div>
            <p class="uses-card-desc">
              Visual explorer for MongoDB. Aggregation pipeline builder is a
              lifesaver.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">📡</span>
              <span class="uses-card-name">WinSCP</span>
              <span class="uses-tag uses-tag-muted">SFTP</span>
            </div>
            <p class="uses-card-desc">
              File transfer to remote servers. Reliable, fast, no drama.
            </p>
          </div>
        </div>
      </section>

      <!-- DATABASES -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ DATABASES ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--orange);"
          >
            <span class="uses-emoji-lg">😅</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name"
                  >SQL Server · MongoDB · PostgreSQL · MySQL</span
                >
                <span class="uses-tag uses-tag-muted">All Installed</span>
              </div>
              <p class="uses-card-desc">
                Yes, all four installed on the same machine. No, they don't all
                run at once — services are started manually on demand to keep
                the old laptop breathing. Smart resource management, not chaos.
                (Okay, maybe a little chaos.)
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICES & INFRASTRUCTURE -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ SERVICES & INFRASTRUCTURE ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--orange);"
          >
            <span class="uses-emoji-lg">🔶</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name">Cloudflare</span>
                <span class="uses-tag uses-tag-green">Favourite</span>
              </div>
              <p class="uses-card-desc">
                WAF, DDoS protection, DNS, and analytics — all in one. Powers
                the Security dashboard on this site. Free plan does more than
                you'd expect.
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">🐳</span>
              <span class="uses-card-name">Docker</span>
              <span class="uses-tag uses-tag-cyan">Daily Driver</span>
            </div>
            <p class="uses-card-desc">
              Containerize everything. Consistent environments from dev to
              production.
            </p>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🔍</span>
              <span class="uses-card-name">Elasticsearch + Kibana</span>
              <span class="uses-tag uses-tag-muted">via Docker</span>
            </div>
            <p class="uses-card-desc">
              Running inside Docker. ES for full-text search and log
              aggregation, Kibana for visualization. Started manually — RAM is
              precious on this machine.
            </p>
          </div>
          <div class="uses-card" style="--accent: #a78bfa;">
            <div class="uses-card-top">
              <span class="uses-emoji">⚙️</span>
              <span class="uses-card-name">GitHub Actions</span>
              <span class="uses-tag uses-tag-muted">CI/CD</span>
            </div>
            <p class="uses-card-desc">
              Automated pipelines for testing, building, and deploying. Simple
              YAML, powerful results.
            </p>
          </div>
        </div>
      </section>

      <!-- PRODUCTIVITY & APPS -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ PRODUCTIVITY & APPS ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div
            class="uses-card uses-card-featured"
            style="--accent: var(--cyan);"
          >
            <span class="uses-emoji-lg">⚡</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name">OpenCode Go — $10/month</span>
                <span class="uses-tag uses-tag-green">Favourite</span>
              </div>
              <p class="uses-card-desc">
                Low-cost AI coding subscription with access to multiple frontier
                open-source models — GLM, Kimi K2, MiniMax, DeepSeek, Qwen. Can
                switch models freely. Used anywhere: terminal, IDE, custom apps.
                <br><a href="https://opencode.ai" target="_blank" rel="noopener noreferrer" class="uses-link">opencode.ai ↗</a>
              </p>
            </div>
          </div>
          <div class="uses-card uses-card-featured" style="--accent: #ffd166;">
            <span class="uses-emoji-lg">🥒</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name"
                  >Big Pickle — Free Model via OpenCode</span
                >
                <span class="uses-tag uses-tag-green">Personal Favourite</span>
              </div>
              <p class="uses-card-desc">
                The best free model on OpenCode. 200K context window, fast
                responses, beats DeepSeek V4 Flash in daily use. Actually an
                alias for GLM-4.6 — 355B parameter MoE model, free during
                feedback period. Smart frugality. 🥒
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">📝</span>
              <span class="uses-card-name">Notepad++</span>
              <span class="uses-tag uses-tag-muted">Quick Edit</span>
            </div>
            <p class="uses-card-desc">
              The trusty text editor that never dies. For quick file edits,
              logs, and anything that doesn't need a full IDE.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">🦙</span>
              <span class="uses-card-name">Ollama Desktop</span>
              <span class="uses-tag uses-tag-muted">Local AI</span>
            </div>
            <p class="uses-card-desc">
              Run LLMs locally. Pairs with OpenCode for offline AI coding — no
              internet, no subscription needed. Subject of my latest Dev.to
              article.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">🎬</span>
              <span class="uses-card-name">CapCut</span>
              <span class="uses-tag uses-tag-muted">Video</span>
            </div>
            <p class="uses-card-desc">
              Quick video editing when needed. Simple, fast, no learning curve.
            </p>
          </div>
          <div class="uses-card" style="--accent: #ffd166;">
            <div class="uses-card-top">
              <span class="uses-emoji">🖼️</span>
              <span class="uses-card-name">FastStone</span>
              <span class="uses-tag uses-tag-muted">Image Viewer</span>
            </div>
            <p class="uses-card-desc">
              Lightweight image viewer and editor. Old-school but blazing fast.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">✂️</span>
              <span class="uses-card-name">Elmocut</span>
              <span class="uses-tag uses-tag-orange">Parenting Tool</span>
            </div>
            <p class="uses-card-desc">
              Network cutter from GitHub — kills internet on specific devices
              via ARP spoofing. Primary use case: cutting my kid's phone
              internet when screen time is up. Works every time. 😄
              <br><a href="https://github.com/elmoiv/elmocut" target="_blank" rel="noopener noreferrer" class="uses-link">github.com/elmoiv/elmocut ↗</a>
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">💬</span>
              <span class="uses-card-name">WhatsApp + Teams</span>
              <span class="uses-tag uses-tag-cyan">Communication</span>
            </div>
            <p class="uses-card-desc">
              WA for everything personal and informal. Teams for enterprise
              meetings and client coordination.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">🎸</span>
              <span class="uses-card-name">Spotify — Rarely</span>
              <span class="uses-tag uses-tag-muted">Selective</span>
            </div>
            <p class="uses-card-desc">
              Rarely opened, but when I do it's always the same songs on repeat:
              The Spirit Carries On (Dream Theater), Wake Me Up When September
              Ends, American Idiot, Boulevard of Broken Dreams, and a few tracks
              from Kotak. No shuffle needed.
            </p>
          </div>
          <div class="uses-card" style="--accent: #a78bfa;">
            <div class="uses-card-top">
              <span class="uses-emoji">📦</span>
              <span class="uses-card-name">Office 365</span>
              <span class="uses-tag uses-tag-muted">Documents</span>
            </div>
            <p class="uses-card-desc">
              Word, Excel, PowerPoint — the inevitable enterprise trio. Can't
              escape it, might as well embrace it.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--green);">
            <div class="uses-card-top">
              <span class="uses-emoji">🌬️</span>
              <span class="uses-card-name">Electric Fan</span>
              <span class="uses-tag uses-tag-orange">Essential</span>
            </div>
            <p class="uses-card-desc">
              Not USB-powered, not smart, not IoT. Just a regular electric fan
              doing God's work in the heat of East Java. The most underrated
              tool in this entire list.
            </p>
          </div>
        </div>
      </section>

      <!-- DAILY RITUAL -->
      <section class="section">
        <div class="section-divider">
          <span class="section-tag">[ DAILY RITUAL ]</span>
          <div class="section-line"></div>
        </div>
        <div class="uses-grid">
          <div class="uses-card uses-card-featured" style="--accent: #ffd166;">
            <span class="uses-emoji-lg">☕</span>
            <div class="uses-card-body">
              <div class="uses-card-top">
                <span class="uses-card-name"
                  >2 Tablespoons Black Coffee — No Sugar</span
                >
                <span class="uses-tag uses-tag-green">Non-Negotiable</span>
              </div>
              <p class="uses-card-desc">
                Not a coffee drinker. A coffee engineer. Two full tablespoons,
                black, no sugar. Strong enough to taste the code. This is the
                morning boot sequence — nothing runs until this is done.
              </p>
            </div>
          </div>
          <div class="uses-card" style="--accent: var(--cyan);">
            <div class="uses-card-top">
              <span class="uses-emoji">🚗</span>
              <span class="uses-card-name">Morning Routine</span>
              <span class="uses-tag uses-tag-cyan">Every Day</span>
            </div>
            <p class="uses-card-desc">
              Drop kid off at school → come home → brew the coffee → open laptop
              → ship code. Simple, consistent, effective. The best systems are
              boring.
            </p>
          </div>
          <div class="uses-card" style="--accent: var(--orange);">
            <div class="uses-card-top">
              <span class="uses-emoji">📱</span>
              <span class="uses-card-name">Smartphone — Rarely Mine</span>
              <span class="uses-tag uses-tag-muted">Borrowed Asset</span>
            </div>
            <p class="uses-card-desc">
