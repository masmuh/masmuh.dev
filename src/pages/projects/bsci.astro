  <div class="bsci">

<header class="bsci-hero">
    <div class="bsci-hero-meta">
      <span class="bsci-badge bsci-badge-corporate">Corporate</span><span class="bsci-badge bsci-badge-client">Boston Scientific</span> 
      <span class="bsci-badge bsci-badge-year">June 2021</span>
    </div>
    <h1 class="bsci-hero-title">DRMS<br><span>Distributor Relationship &amp; SAP Integration Platform</span></h1>
    <p class="bsci-hero-desc">An enterprise SAP Business ByDesign integration middleware comprising two components: a REST API gateway that exposes SAP ERP functions (sales orders, credit notes, returns, stock transfers) as JSON endpoints for external applications, and a background scheduler that periodically extracts SAP master/transactional data to CSV files for a third-party B2B analytics gateway.</p>
    <div class="bsci-stack-pills">
      <span class="bsci-stack-pill">.NET 5</span><span class="bsci-stack-pill">ASP.NET Core</span><span class="bsci-stack-pill">Web API</span><span class="bsci-stack-pill">SOAP/WCF</span><span class="bsci-stack-pill">OData</span><span class="bsci-stack-pill">Redis</span><span class="bsci-stack-pill">CsvHelper</span><span class="bsci-stack-pill">Swagger</span><span class="bsci-stack-pill">MailKit</span><span class="bsci-stack-pill">Worker Service</span>
    </div>
  </header>

  <section class="bsci-section">
    <div class="bsci-section-label">
      <span class="bsci-section-label-num">01</span>
      <span class="bsci-section-label-text">Impact &amp; Metrics</span>
      <span class="bsci-section-label-line"></span>
    </div>
    <div class="bsci-metrics-grid">
      <div class="bsci-metric-card bsci-amber"><div class="bsci-metric-val">62K</div><div class="bsci-metric-label">Lines of Code</div><div class="bsci-metric-sub">C# — 167 source files</div></div>
      <div class="bsci-metric-card bsci-amber"><div class="bsci-metric-val">6</div><div class="bsci-metric-label">REST API Endpoints</div><div class="bsci-metric-sub">Sales Order, Credit Note, Returns</div></div>
      <div class="bsci-metric-card bsci-blue"><div class="bsci-metric-val">6</div><div class="bsci-metric-label">Background Workers</div><div class="bsci-metric-sub">CSV export to B2B gateway</div></div>
      <div class="bsci-metric-card bsci-amber"><div class="bsci-metric-val">6</div><div class="bsci-metric-label">Complexity Rating</div><div class="bsci-metric-sub">Enterprise Application</div></div>
    </div>
    <div class="bsci-impact-wrapper" style="margin-top:20px">
      <table class="bsci-impact-table">
        <thead><tr><th>Area</th><th>Before</th><th>After</th><th></th></tr></thead>
        <tbody>
          <tr><td class="bsci-row-label">SAP Integration</td><td class="bsci-before">Direct SOAP calls, no abstraction</td><td class="bsci-after">Clean REST API with Swagger docs + auth</td><td class="bsci-delta">+ standardized</td></tr>
          <tr><td class="bsci-row-label">Data Distribution</td><td class="bsci-before">Manual CSV exports</td><td class="bsci-after">6 automated workers with Redis cache</td><td class="bsci-delta">+ fully automated</td></tr>
          <tr><td class="bsci-row-label">Error Handling</td><td class="bsci-before">Unhandled SOAP faults</td><td class="bsci-after">Structured ResultApi + email notification</td><td class="bsci-delta">+ observable</td></tr>
          <tr><td class="bsci-row-label">Deployment</td><td class="bsci-before">Manual IIS deploys</td><td class="bsci-after">Windows Service + certificate auth</td><td class="bsci-delta">+ secure</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="bsci-section">
    <div class="bsci-section-label">
      <span class="bsci-section-label-num">02</span>
      <span class="bsci-section-label-text">Architecture</span>
      <span class="bsci-section-label-line"></span>
    </div>
    <div class="bsci-arch-diagram">
      <div class="bsci-arch-diagram-inner">
        <div class="bsci-arch-node"><div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">External Apps</div><div class="bsci-arch-node-sub">REST JSON clients</div></div>
        <div class="bsci-arch-arrow"><div class="bsci-arch-arrow-line"></div><div class="bsci-arch-arrow-label">REST API</div></div>
        <div class="bsci-arch-node core">
          <div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">DRMS API Gateway</div><div class="bsci-arch-node-sub">ASP.NET Core 5 - Swagger</div>
          <div class="bsci-core-stack">
            <div class="bsci-core-step"><span class="bsci-core-step-dot"></span>Controllers — JSON in/out</div>
            <div class="bsci-core-step"><span class="bsci-core-step-dot bsci-blue"></span>Services — Business Logic</div>
            <div class="bsci-core-step"><span class="bsci-core-step-dot"></span>SOAP/OData — SAP ByDesign</div>
          </div>
        </div>
        <div class="bsci-arch-arrow"><div class="bsci-arch-arrow-line"></div><div class="bsci-arch-arrow-label">SOAP</div></div>
        <div class="bsci-arch-node"><div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">SAP ByDesign</div><div class="bsci-arch-node-sub">Cloud ERP</div></div>
      </div>
    </div>
    <div style="margin-top:20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:center">
      <div class="bsci-arch-node bsci-db-node"><div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">Scheduler</div><div class="bsci-arch-node-sub">Worker Service - Cronos</div></div>
      <div class="bsci-arch-arrow" style="min-width:40px"><div class="bsci-arch-arrow-line" style="width:20px"></div><div class="bsci-arch-arrow-label">CSV</div></div>
      <div class="bsci-arch-node bsci-db-node"><div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">B2B Gateway</div><div class="bsci-arch-node-sub">b2bgw.bsci.com</div></div>
      <div class="bsci-arch-arrow" style="min-width:40px"><div class="bsci-arch-arrow-line" style="width:20px"></div><div class="bsci-arch-arrow-label">cache</div></div>
      <div class="bsci-arch-node bsci-db-node"><div class="bsci-arch-node-icon"></div><div class="bsci-arch-node-label">Redis</div><div class="bsci-arch-node-sub">Cache tracking</div></div>
    </div>
  </section>

  <section class="bsci-section">
    <div class="bsci-section-label">
      <span class="bsci-section-label-num">03</span>
      <span class="bsci-section-label-text">Key Capabilities</span>
      <span class="bsci-section-label-line"></span>
    </div>
    <div class="bsci-cap-list">
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Sales Order creation in SAP ByDesign via REST JSON</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Credit Note processing with/without stock impact</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Return Order (Inbound Delivery Notification)</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Stock Transfer Order (Customer Demand)</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Customer Invoice CSV export to B2B gateway</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Customer &amp; Material master CSV sync</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Account Receivables (all/open/prev-month) CSV</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Pricelist data extraction to CSV</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Posted Inbound Logistics CSV reporting</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Redis cache for incremental data tracking</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Email notifications on job success/failure</div>
      <div class="bsci-cap-item"><span class="bsci-cap-icon"></span>Certificate + Basic Auth security</div>
    </div>
  </section>

  <section class="bsci-section">
    <div class="bsci-section-label">
      <span class="bsci-section-label-num">04</span>
      <span class="bsci-section-label-text">Decision Log</span>
      <span class="bsci-section-label-line"></span>
    </div>
    <div class="bsci-decision-list">
      <div class="bsci-decision-card">
        <div class="bsci-decision-header">
          <span class="bsci-decision-num">01</span>
          <div>
            <div class="bsci-decision-title">Clean Architecture Over Traditional N-Tier</div>
            <div class="bsci-decision-problem">The DRMS needed to be both a REST API gateway and a background scheduler sharing the same business logic. Traditional N-tier would have caused code duplication or tight coupling between the two runtimes.</div>
          </div>
        </div>
        <div class="bsci-decision-body">
          <div>
            <div class="bsci-decision-col-label bsci-chosen">Chosen — Clean Architecture</div>
            <div class="bsci-decision-col-text">drms.domain held pure DTOs with zero dependencies. drms.application housed all business logic (21 service modules) and SOAP/OData connectivity. Both drms-api and scheduler depended on drms.application — sharing 100% of business logic across two entry points.</div>
          </div>
          <div>
            <div class="bsci-decision-col-label bsci-tradeoff">Tradeoff — Monolithic API + Scheduler</div>
            <div class="bsci-decision-col-text">Combining them would have simplified deployment but created availability coupling. Clean architecture overhead was minimal compared to operational independence gained.</div>
          </div>
        </div>
        <div class="bsci-decision-code">
<pre><span class="bsci-token-cm">// Shared service consumed by both API and Scheduler</span>
<span class="bsci-token-kw">public class</span> <span class="bsci-token-fn">SalesOrderService</span> : ISalesOrderService
&#123;
    <span class="bsci-token-kw">public async</span> Task&lt;ResultApi&gt; <span class="bsci-token-fn">Insert</span>(string url, string user, string pass, SalesOrderParam param)
    &#123;
        <span class="bsci-token-kw">var</span> client = <span class="bsci-token-kw">new</span> <span class="bsci-token-fn">ServiceSalesOrderClient</span>(...);
        <span class="bsci-token-kw">return await</span> client.<span class="bsci-token-fn">ManageSalesOrderInAsync</span>(<span class="bsci-token-fn">MapFromParam</span>(param));
    &#125;
&#125;</pre>
        </div>
      </div>

      <div class="bsci-decision-card">
        <div class="bsci-decision-header">
          <span class="bsci-decision-num">02</span>
          <div>
            <div class="bsci-decision-title">SOAP + OData Dual Strategy for SAP ByD</div>
            <div class="bsci-decision-problem">SAP ByDesign exposes SOAP (WCF) for transactional writes and OData REST for queries. SOAP is rich but slow; OData is fast but limited for writes. Choosing one would limit functionality.</div>
          </div>
        </div>
        <div class="bsci-decision-body">
          <div>
            <div class="bsci-decision-col-label bsci-chosen">Chosen — SOAP for writes, OData for reads</div>
            <div class="bsci-decision-col-text">Sales Order creation and Credit Note posting used SOAP via WCF Connected Services. Bulk data population (products, customers, invoices) used OData with pagination for performance. Redis cache tracked OData state.</div>
          </div>
          <div>
            <div class="bsci-decision-col-label bsci-tradeoff">Tradeoff — Single protocol</div>
            <div class="bsci-decision-col-text">Pure SOAP would be too slow for 3000+ records hourly. Pure OData lacked transactional depth. Dual approach optimized for each use case.</div>
          </div>
        </div>
        <div class="bsci-decision-code">
<pre><span class="bsci-token-cm">// OData paginated read (fast)</span>
<span class="bsci-token-kw">var</span> response = <span class="bsci-token-kw">await</span> _httpClient.<span class="bsci-token-fn">GetAsync</span>(
    <span class="bsci-token-str">$"&#123;url&#125;/sap/byd/odata/.../ProductCollection?$top=3000&$skip=&#123;skip&#125;"</span>);

<span class="bsci-token-cm">// SOAP transactional write (reliable)</span>
<span class="bsci-token-kw">var</span> client = <span class="bsci-token-kw">new</span> <span class="bsci-token-fn">ServiceSalesOrderClient</span>(...);
<span class="bsci-token-kw">var</span> result = <span class="bsci-token-kw">await</span> client.<span class="bsci-token-fn">ManageSalesOrderInAsync</span>(request);</pre>
        </div>
      </div>

      <div class="bsci-decision-card">
        <div class="bsci-decision-header">
          <span class="bsci-decision-num">03</span>
          <div>
            <div class="bsci-decision-title">Redis Cache for Scheduler State Tracking</div>
            <div class="bsci-decision-problem">Six background workers ran on intervals to extract SAP data to CSV. Without state tracking, every run would duplicate records and waste API quota. File-based tracking would fail on restarts.</div>
          </div>
        </div>
        <div class="bsci-decision-body">
          <div>
            <div class="bsci-decision-col-label bsci-chosen">Chosen — Redis Cache</div>
            <div class="bsci-decision-col-text">Each worker stored its last run timestamp and processed IDs in Redis. Workers checked Redis before fetching to only retrieve new records. Cache expiration ensured eventual re-sync.</div>
          </div>
          <div>
            <div class="bsci-decision-col-label bsci-tradeoff">Tradeoff — SQL Server / File-based</div>
            <div class="bsci-decision-col-text">SQL Server added latency. Files lost data on permission changes. Redis provided sub-ms access, built-in expiration, and survived restarts.</div>
          </div>
        </div>
        <div class="bsci-decision-code">
<pre><span class="bsci-token-cm">// Redis cache check before OData fetch</span>
<span class="bsci-token-kw">var</span> cached = <span class="bsci-token-kw">await</span> _cache.<span class="bsci-token-fn">GetAsync</span>(cacheKey);
<span class="bsci-token-kw">if</span> (cached != <span class="bsci-token-kw">null</span>) <span class="bsci-token-kw">return</span> cached;

<span class="bsci-token-kw">var</span> data = <span class="bsci-token-kw">await</span> <span class="bsci-token-fn">FetchFromOData</span>(url, user, pass);
<span class="bsci-token-kw">await</span> _cache.<span class="bsci-token-fn">SetAsync</span>(cacheKey, data, TimeSpan.FromHours(1));</pre>
        </div>
      </div>
    </div>
  </section>

  <section class="bsci-section">
    <div class="bsci-section-label">
      <span class="bsci-section-label-num">05</span>
      <span class="bsci-section-label-text">Tech Stack</span>
      <span class="bsci-section-label-line"></span>
    </div>
    <div class="bsci-arch-diagram">
      <table class="bsci-stack-table">
        <tr><td class="bsci-layer">Runtime</td><td class="bsci-tech">.NET 5.0, ASP.NET Core, Kestrel</td></tr>
        <tr><td class="bsci-layer">API Layer</td><td class="bsci-tech">ASP.NET Core Web API, Swashbuckle 5.6, Basic + Certificate Auth</td></tr>
        <tr><td class="bsci-layer">SAP Integration</td><td class="bsci-tech">SOAP via WCF Connected Services, OData REST, CSRF token handling</td></tr>
        <tr><td class="bsci-layer">Scheduler</td><td class="bsci-tech">.NET Worker Service, Cronos 0.7, IHostedService, Windows Service</td></tr>
        <tr><td class="bsci-layer">Data Export</td><td class="bsci-tech">CsvHelper 27.1, CSV generation, SFTP upload to B2B gateway</td></tr>
        <tr><td class="bsci-layer">Caching</td><td class="bsci-tech">StackExchange.Redis 6.0, Redis localhost</td></tr>
        <tr><td class="bsci-layer">Messaging</td><td class="bsci-tech">MailKit 2.15, MimeKit 2.15, SMTP Office 365</td></tr>
        <tr><td class="bsci-layer">Serialization</td><td class="bsci-tech">Newtonsoft.Json 13.0, System.Text.Json</td></tr>
        <tr><td class="bsci-layer">Architecture</td><td class="bsci-tech">Clean Architecture: domain / application / api / scheduler</td></tr>
      </table>
    </div>
  </section>

  </div>

  <footer>
    <div class="footer-txt">&copy; 2026 Mas Muhammad</div>
    <div class="footer-txt">Built with <span>Astro</span></div>
  </footer>
</Layout>

