      <span class="insentif-alpha-section-label-text">Capabilities</span>
      <span class="insentif-alpha-section-label-line"></span>
    </div>

    <div class="insentif-alpha-metrics-grid">
      <div class="insentif-alpha-metric-card">
        <div class="insentif-alpha-metric-val" style="font-size:26px;"> Monthly</div>
        <div class="insentif-alpha-metric-label">Incentive Periods</div>
        <div class="insentif-alpha-metric-sub">Monthly + Quarterly + Yearly calculation cycles with configurable rules per period</div>
      </div>
      <div class="insentif-alpha-metric-card">
        <div class="insentif-alpha-metric-val" style="font-size:26px;"> Excel</div>
        <div class="insentif-alpha-metric-label">Data Upload</div>
        <div class="insentif-alpha-metric-sub">Excel-based sales and budget data import with validation and error reporting</div>
      </div>
      <div class="insentif-alpha-metric-card insentif-alpha-amber">
        <div class="insentif-alpha-metric-val" style="font-size:26px;"> Role-Based</div>
        <div class="insentif-alpha-metric-label">Access Control</div>
        <div class="insentif-alpha-metric-sub">ADMIN, Area Manager (AM), Sales Manager (SM) roles via Windows Authentication</div>
      </div>
      <div class="insentif-alpha-metric-card">
        <div class="insentif-alpha-metric-val" style="font-size:26px;"> SSRS</div>
        <div class="insentif-alpha-metric-label">Reporting</div>
        <div class="insentif-alpha-metric-sub">SQL Server Reporting Services (RDLC) with drill-down and export capabilities</div>
