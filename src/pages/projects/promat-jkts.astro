---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="e-Promat: Enterprise Material Logistics - Mas Muhammad" description="An enterprise promotional material logistics system for Sanofi managing the full lifecycle of promotional items from procurement to distribution, inventory management, and destruction. Built with VB.NET ASP.NET WebForms with multi-level approval workflows.">
  <nav>
    <a href="/portfolio" class="nav-logo">MAS<span>.</span>MUH</a>
    <a href="/portfolio" class="nav-back">&larr; Back to Portfolio</a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
      <span class="theme-icon-light">&#9728;&#65039;</span>
      <span class="theme-icon-dark">&#127769;</span>
    </button>
    <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- MOBILE NAV PANEL -->
  <div class="mobile-overlay" id="mobileOverlay"></div>
  <div class="mobile-nav" id="mobileNav">
    <div class="mobile-nav-header">
      <div class="nav-logo">MAS<span>.</span>MUH</div>
      <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">&#10005;</button>
    </div>
    <ul class="mobile-nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/portfolio">Portfolio</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <button class="mobile-nav-toggle" id="mobileThemeToggle">Toggle Theme</button>
  </div>

  <div class="promat-jkts">

<header class="promat-jkts-hero">
    <div class="promat-jkts-hero-meta">
      <span class="promat-jkts-badge promat-jkts-badge-corporate">Corporate</span><span class="promat-jkts-badge promat-jkts-badge-client">Sanofi</span> 
      
      <span class="promat-jkts-badge promat-jkts-badge-domain">Pharma / Material Logistics</span>
      <span class="promat-jkts-badge promat-jkts-badge-year">October 2014</span>
    </div>
    <h1 class="promat-jkts-hero-title">e-Promat <span>Enterprise Material Logistics</span><span class="promat-jkts-cursor"></span></h1>
    <p class="promat-jkts-hero-desc">
      An enterprise promotional material logistics system for Sanofi managing the full lifecycle of promotional items from procurement to distribution, inventory management, and destruction. Built with VB.NET ASP.NET WebForms with multi-level approval workflows.
    </p>
    <div class="promat-jkts-stack-pills">
      <span class="promat-jkts-stack-pill">VB.NET</span>
      <span class="promat-jkts-stack-pill">ASP.NET WebForms</span>
      <span class="promat-jkts-stack-pill">.NET 2.0</span>
      <span class="promat-jkts-stack-pill">SQL Server</span>
      <span class="promat-jkts-stack-pill">AjaxControlToolkit</span>
      <span class="promat-jkts-stack-pill">SSRS Reports</span>
      <span class="promat-jkts-stack-pill">30+ Tables</span>
    </div>
  </header>

  <section class="promat-jkts-section">
    <div class="promat-jkts-section-label">
      <span class="promat-jkts-section-label-text">Impact</span>
      <div class="promat-jkts-section-label-line"></div>
      <span class="promat-jkts-section-label-num">01</span>
    </div>
    <div class="promat-jkts-metrics-grid">
      <div class="promat-jkts-metric-card">
        <div class="promat-jkts-metric-val">8,300+</div>
        <div class="promat-jkts-metric-label">Lines of Code</div>
        <div class="promat-jkts-metric-sub">VB.NET code-behind</div>
      </div>
      <div class="promat-jkts-metric-card promat-jkts-amber">
        <div class="promat-jkts-metric-val">0</div>
        <div class="promat-jkts-metric-label">API Endpoints</div>
        <div class="promat-jkts-metric-sub">Traditional WebForms</div>
      </div>
      <div class="promat-jkts-metric-card promat-jkts-amber">
        <div class="promat-jkts-metric-val">30+</div>
        <div class="promat-jkts-metric-label">Database Tables</div>
        <div class="promat-jkts-metric-sub">SQL Server relational</div>
      </div>
      <div class="promat-jkts-metric-card promat-jkts-red">
        <div class="promat-jkts-metric-val">10</div>
        <div class="promat-jkts-metric-label">Complexity Score</div>
        <div class="promat-jkts-metric-sub">Mission Critical</div>
      </div>
    </div>
  </section>

  <section class="promat-jkts-section">
    <div class="promat-jkts-section-label">
      <span class="promat-jkts-section-label-text">Architecture</span>
      <div class="promat-jkts-section-label-line"></div>
      <span class="promat-jkts-section-label-num">02</span>
    </div>
    <div class="promat-jkts-arch-diagram">
      <div class="promat-jkts-arch-diagram-inner">

        <div class="promat-jkts-arch-node promat-jkts-source">
          <div class="promat-jkts-arch-node-icon"></div>
          <div class="promat-jkts-arch-node-label">ASPX Pages</div>
          <div class="promat-jkts-arch-node-sub">UI / Presentation</div>
        </div>

        <div class="promat-jkts-arch-arrow">
          <div class="promat-jkts-arch-arrow-line"></div>
          <div class="promat-jkts-arch-arrow-label">postback</div>
        </div>

        <div style="display:flex; flex-direction:column; align-items:center; gap:0;">
          <div class="promat-jkts-arch-node core" style="width:220px;">
            <div class="promat-jkts-arch-node-label" style="font-size:13px; margin-bottom:10px;">Code-Behind Layer</div>
            <div class="promat-jkts-core-stack">
              <div class="promat-jkts-core-step">
                <div class="promat-jkts-core-step-dot"></div>
                Event handlers · Page_Load
              </div>
              <div class="promat-jkts-core-step">
                <div class="promat-jkts-core-step-dot"></div>
                Approval workflow logic
              </div>
              <div class="promat-jkts-core-step">
                <div class="promat-jkts-core-step-dot" style="background:var(--blue)"></div>
                ADO.NET · Stored Procedures
              </div>
            </div>
          </div>
          <div class="promat-jkts-schema-connector" style="margin-top:0;">
            <div class="promat-jkts-schema-line-v"></div>
            <div class="promat-jkts-schema-arrow-label">30+ tables</div>
            <div class="promat-jkts-schema-line-v"></div>
            <div class="promat-jkts-arch-node promat-jkts-schema-node">
              <div class="promat-jkts-arch-node-label" style="font-size:11px; color: #f59e0b;">SQL Server</div>
              <div class="promat-jkts-arch-node-sub">Stored Procedures</div>
            </div>
          </div>
        </div>

        <div style="display:flex; flex-direction:column; align-items:center;">
          <div class="promat-jkts-arch-arrow">
            <div class="promat-jkts-arch-arrow-line"></div>
            <div class="promat-jkts-arch-arrow-label">email</div>
          </div>
          <div class="promat-jkts-arch-node promat-jkts-output" style="margin-top:4px;">
            <div class="promat-jkts-arch-node-icon"></div>
            <div class="promat-jkts-arch-node-label">SMTP Notification</div>
            <div class="promat-jkts-arch-node-sub">Approval workflow</div>
          </div>
          <div class="promat-jkts-schema-connector" style="margin-top:8px;">
            <div class="promat-jkts-schema-line-v"></div>
            <div class="promat-jkts-schema-arrow-label">reports</div>
            <div class="promat-jkts-schema-line-v"></div>
            <div class="promat-jkts-arch-node promat-jkts-schema-node">
              <div class="promat-jkts-arch-node-label" style="font-size:11px; color: #f59e0b;">SSRS Reports</div>
              <div class="promat-jkts-arch-node-sub">Transaction reporting</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="promat-jkts-section">
    <div class="promat-jkts-section-label">
      <span class="promat-jkts-section-label-text">Decision Log</span>
      <div class="promat-jkts-section-label-line"></div>
      <span class="promat-jkts-section-label-num">03</span>
    </div>
    <div class="promat-jkts-decision-list">

      <div class="promat-jkts-decision-card">
        <div class="promat-jkts-decision-header">
          <div class="promat-jkts-decision-num">01</div>
          <div>
            <div class="promat-jkts-decision-title">Multi-Level Approval Workflow with Email Notification</div>
            <div class="promat-jkts-decision-problem">
              Purchase orders and destruction requests require sequential approval from multiple hierarchy levels. Manual email/paper approvals caused delays and lost requests.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-body">
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-chosen">▸ Chosen</div>
            <div class="promat-jkts-decision-col-text">
              State-machine approval engine with configurable approval chains. Each transaction tracks its current status and next approver. SMTP email notifications trigger on status transitions with direct action links.
            </div>
          </div>
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-tradeoff">▸ Trade-off</div>
            <div class="promat-jkts-decision-col-text">
              Sequential approval adds processing latency for high-volume orders. A parallel approval model would be faster but risks inconsistent decisions. Sequential was chosen for audit integrity.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-code">
<pre><span class="promat-jkts-token-cm">' Approval state machine — status transitions</span>
<span class="promat-jkts-token-kw">Select Case</span> currentStatus
    <span class="promat-jkts-token-kw">Case</span> <span class="promat-jkts-token-str">"DRAFT"</span>
        UpdateStatus(orderId, <span class="promat-jkts-token-str">"PENDING_APPROVAL"</span>)
        SendApprovalEmail(orderId, level1Approver)
    <span class="promat-jkts-token-kw">Case</span> <span class="promat-jkts-token-str">"PENDING_APPROVAL"</span>
        <span class="promat-jkts-token-kw">If</span> isLevel1Approval <span class="promat-jkts-token-kw">Then</span>
            UpdateStatus(orderId, <span class="promat-jkts-token-str">"LEVEL2_APPROVAL"</span>)
            SendApprovalEmail(orderId, level2Approver)
        <span class="promat-jkts-token-kw">End If</span>
    <span class="promat-jkts-token-kw">Case</span> <span class="promat-jkts-token-str">"LEVEL2_APPROVAL"</span>
        UpdateStatus(orderId, <span class="promat-jkts-token-str">"APPROVED"</span>)
        NotifyRequester(orderId, <span class="promat-jkts-token-str">"Order approved"</span>)
<span class="promat-jkts-token-kw">End Select</span></pre>
        </div>
      </div>

      <div class="promat-jkts-decision-card">
        <div class="promat-jkts-decision-header">
          <div class="promat-jkts-decision-num">02</div>
          <div>
            <div class="promat-jkts-decision-title">VB.NET Code-Behind over MVC / Web API</div>
            <div class="promat-jkts-decision-problem">
              Greenfield project in 2013 within Sanofi's .NET 2.0 standardized environment. Need to align with corporate technology roadmap and existing infrastructure.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-body">
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-chosen">▸ Chosen</div>
            <div class="promat-jkts-decision-col-text">
              Classic ASP.NET WebForms with VB.NET code-behind. Matches the corporate .NET 2.0 standard. Server controls with AjaxControlToolkit for interactive UI without writing JavaScript-heavy frontends.
            </div>
          </div>
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-tradeoff">▸ Trade-off</div>
            <div class="promat-jkts-decision-col-text">
              Tight coupling between UI and logic through code-behind. No separation of concerns compared to MVC. Acceptable for a departmental system with a small dev team focused on rapid delivery.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-code">
<pre><span class="promat-jkts-token-cm">' VB.NET code-behind pattern — Page_Load data binding</span>
<span class="promat-jkts-token-kw">Protected Sub</span> <span class="promat-jkts-token-fn">Page_Load</span>(<span class="promat-jkts-token-kw">ByVal</span> sender <span class="promat-jkts-token-kw">As</span> Object,
    <span class="promat-jkts-token-kw">ByVal</span> e <span class="promat-jkts-token-kw">As</span> EventArgs) <span class="promat-jkts-token-kw">Handles</span> Me.Load
    <span class="promat-jkts-token-kw">If Not</span> IsPostBack <span class="promat-jkts-token-kw">Then</span>
        BindMaterialGrid()
        LoadDropdowns()
    <span class="promat-jkts-token-kw">End If</span>
<span class="promat-jkts-token-kw">End Sub</span>

<span class="promat-jkts-token-kw">Private Sub</span> <span class="promat-jkts-token-fn">BindMaterialGrid</span>()
    <span class="promat-jkts-token-kw">Dim</span> dt <span class="promat-jkts-token-kw">As</span> DataTable = ExecuteSP(<span class="promat-jkts-token-str">"sp_Promat_GetMaterials"</span>, Nothing)
    gvMaterials.DataSource = dt
    gvMaterials.DataBind()
<span class="promat-jkts-token-kw">End Sub</span></pre>
        </div>
      </div>

      <div class="promat-jkts-decision-card">
        <div class="promat-jkts-decision-header">
          <div class="promat-jkts-decision-num">03</div>
          <div>
            <div class="promat-jkts-decision-title">Stored Procedures for Data Access Layer</div>
            <div class="promat-jkts-decision-problem">
              Complex inventory queries with multi-table joins, stock calculations, and approval status filtering. ORM overhead was unacceptable for the transaction volume and query complexity.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-body">
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-chosen">▸ Chosen</div>
            <div class="promat-jkts-decision-col-text">
              All data access through SQL Server stored procedures. ADO.NET calls via SqlCommand with CommandType.StoredProcedure. Centralized query logic for DBA optimization and auditing.
            </div>
          </div>
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-tradeoff">▸ Trade-off</div>
            <div class="promat-jkts-decision-col-text">
              Business logic split between VB.NET code and stored procedures. Debugging requires both SSMS and Visual Studio. But performance on complex inventory rollups justified the approach.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-code">
<pre><span class="promat-jkts-token-cm">' Stored procedure call from code-behind</span>
<span class="promat-jkts-token-kw">Private Function</span> <span class="promat-jkts-token-fn">ExecuteSP</span>(<span class="promat-jkts-token-kw">ByVal</span> spName <span class="promat-jkts-token-kw">As</span> <span class="promat-jkts-token-mth">String</span>,
    <span class="promat-jkts-token-kw">ByVal</span> params <span class="promat-jkts-token-kw">As</span> List(<span class="promat-jkts-token-kw">Of</span> SqlParameter)) <span class="promat-jkts-token-kw">As</span> DataTable
    <span class="promat-jkts-token-kw">Using</span> conn <span class="promat-jkts-token-kw">As</span> <span class="promat-jkts-token-kw">New</span> <span class="promat-jkts-token-fn">SqlConnection</span>(connString)
        <span class="promat-jkts-token-kw">Using</span> cmd <span class="promat-jkts-token-kw">As</span> <span class="promat-jkts-token-kw">New</span> <span class="promat-jkts-token-fn">SqlCommand</span>(spName, conn)
            cmd.CommandType = CommandType.StoredProcedure
            <span class="promat-jkts-token-kw">If</span> params <span class="promat-jkts-token-kw">IsNot</span> <span class="promat-jkts-token-kw">Nothing</span> <span class="promat-jkts-token-kw">Then</span>
                cmd.Parameters.AddRange(params.ToArray())
            <span class="promat-jkts-token-kw">End If</span>
            <span class="promat-jkts-token-kw">Dim</span> da <span class="promat-jkts-token-kw">As</span> <span class="promat-jkts-token-kw">New</span> <span class="promat-jkts-token-fn">SqlDataAdapter</span>(cmd)
            <span class="promat-jkts-token-kw">Dim</span> dt <span class="promat-jkts-token-kw">As</span> <span class="promat-jkts-token-kw">New</span> DataTable()
            da.Fill(dt)
            <span class="promat-jkts-token-kw">Return</span> dt
        <span class="promat-jkts-token-kw">End Using</span>
    <span class="promat-jkts-token-kw">End Using</span>
<span class="promat-jkts-token-kw">End Function</span></pre>
        </div>
      </div>

      <div class="promat-jkts-decision-card">
        <div class="promat-jkts-decision-header">
          <div class="promat-jkts-decision-num">04</div>
          <div>
            <div class="promat-jkts-decision-title">SSRS Reports over Ad-Hoc Reporting</div>
            <div class="promat-jkts-decision-problem">
              Regulatory and audit requirements demand formal, printable reports for procurement, inventory, destruction, and distribution transactions. Ad-hoc query tools insufficient.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-body">
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-chosen">▸ Chosen</div>
            <div class="promat-jkts-decision-col-text">
              SQL Server Reporting Services (SSRS) for all transaction types. Parameterized reports with date ranges, branch filters, and status filters. Rendered as PDF for archival and audit sign-off.
            </div>
          </div>
          <div>
            <div class="promat-jkts-decision-col-label promat-jkts-tradeoff">▸ Trade-off</div>
            <div class="promat-jkts-decision-col-text">
              SSRS requires Report Server infrastructure and licensing. Report embedding in WebForms requires ReportViewer control. Static report layouts require DBA/developer changes for modifications.
            </div>
          </div>
        </div>
        <div class="promat-jkts-decision-code">
<pre><span class="promat-jkts-token-cm">' SSRS ReportViewer in ASPX page</span>
&lt;rsweb:ReportViewer ID=<span class="promat-jkts-token-str">"rvDestruction"</span> runat=<span class="promat-jkts-token-str">"server"</span>
    ProcessingMode=<span class="promat-jkts-token-str">"Remote"</span>
    ServerUrl=<span class="promat-jkts-token-str">"http://report-server/ReportServer"</span>
    ReportPath=<span class="promat-jkts-token-str">"/PromatReports/rpt_DestructionCertificate"</span>
    Width=<span class="promat-jkts-token-str">"100%"</span> Height=<span class="promat-jkts-token-str">"600px"</span> /&gt;

<span class="promat-jkts-token-cm">' Code-behind parameter binding</span>
rvDestruction.ServerReport.<span class="promat-jkts-token-fn">SetParameters</span>(
    <span class="promat-jkts-token-kw">New</span> List(<span class="promat-jkts-token-kw">Of</span> ReportParameter) <span class="promat-jkts-token-kw">From</span> &#123;
        <span class="promat-jkts-token-kw">New</span> ReportParameter(<span class="promat-jkts-token-str">"DestructionID"</span>, destructionId)
    &#125;)</pre>
        </div>
      </div>

    </div>
  </section>

  <section class="promat-jkts-section">
    <div class="promat-jkts-section-label">
      <span class="promat-jkts-section-label-text">Business Impact</span>
      <div class="promat-jkts-section-label-line"></div>
      <span class="promat-jkts-section-label-num">04</span>
    </div>
