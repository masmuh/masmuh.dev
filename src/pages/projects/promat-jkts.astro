          <tr>
            <td class="promat-jkts-row-label">Material lifecycle</td>
            <td class="promat-jkts-before">Spreadsheets / email</td>
            <td class="promat-jkts-after">End-to-end system</td>
            <td class="promat-jkts-delta">Full traceability</td>
          </tr>
          <tr>
            <td class="promat-jkts-row-label">Approval process</td>
            <td class="promat-jkts-before">Manual email / paper</td>
            <td class="promat-jkts-after">Multi-level workflow</td>
            <td class="promat-jkts-delta">Audit trail + auto-notify</td>
          </tr>
          <tr>
            <td class="promat-jkts-row-label">Branch inventory</td>
            <td class="promat-jkts-before">Regional silos</td>
            <td class="promat-jkts-after">Centralized visibility</td>
            <td class="promat-jkts-delta">Real-time stock across regions</td>
          </tr>
          <tr>
            <td class="promat-jkts-row-label">Compliance reporting</td>
            <td class="promat-jkts-before">Manual report compilation</td>
            <td class="promat-jkts-after">SSRS on-demand reports</td>
            <td class="promat-jkts-delta">Regulatory-ready in minutes</td>
          </tr>
          <tr>
            <td class="promat-jkts-row-label">Unauthorized spend</td>
            <td class="promat-jkts-before">No approval enforcement</td>
            <td class="promat-jkts-after">Chain-of-approval enforced</td>
            <td class="promat-jkts-delta">Significant cost reduction</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="promat-jkts-section">
    <div class="promat-jkts-section-label">
      <span class="promat-jkts-section-label-text">Tech Stack</span>
      <div class="promat-jkts-section-label-line"></div>
      <span class="promat-jkts-section-label-num">05</span>
    </div>
    <div class="promat-jkts-impact-wrapper">
      <table class="promat-jkts-stack-table">
        <tbody>
          <tr>
            <td class="promat-jkts-layer">Framework</td>
            <td class="promat-jkts-tech">ASP.NET WebForms · .NET Framework 2.0</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Language</td>
            <td class="promat-jkts-tech">VB.NET</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Database</td>
            <td class="promat-jkts-tech">SQL Server (30+ tables)</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Data Access</td>
            <td class="promat-jkts-tech">ADO.NET · Stored Procedures</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">UI Toolkit</td>
            <td class="promat-jkts-tech">AjaxControlToolkit · Server Controls</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Reporting</td>
            <td class="promat-jkts-tech">SQL Server Reporting Services (SSRS)</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Notifications</td>
            <td class="promat-jkts-tech">SMTP Email (System.Net.Mail)</td>
          </tr>
          <tr>
            <td class="promat-jkts-layer">Architecture</td>
            <td class="promat-jkts-tech">ASPX → Code-Behind → SP → SQL Server</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  </div>

  <footer>
    <div class="footer-txt">&copy; 2026 Mas Muhammad</div>
    <div class="footer-txt">Built with <span>Astro</span></div>
  </footer>
</Layout>

<style is:global>

  .promat-jkts {
    --promat-jkts-bg: #0a0b0d;
    --promat-jkts-bg2: #0f1114;
    --promat-jkts-bg3: #141720;
    --promat-jkts-surface: #1a1e28;
    --promat-jkts-surface2: #212636;
    --promat-jkts-border: #2a2f40;
    --promat-jkts-border2: #363c50;
    --promat-jkts-accent: #00e5a0;
    --promat-jkts-accent2: #00b87a;
    --promat-jkts-accent-dim: rgba(0, 229, 160, 0.08);
    --promat-jkts-accent-dim2: rgba(0, 229, 160, 0.15);
    --promat-jkts-amber: #f59e0b;
    --promat-jkts-amber-dim: rgba(245, 158, 11, 0.1);
    --promat-jkts-blue: #60a5fa;
    --promat-jkts-blue-dim: rgba(96, 165, 250, 0.1);
    --promat-jkts-red: #f87171;
    --promat-jkts-text: #e8eaf0;
    --promat-jkts-text2: #8b92a8;
    --promat-jkts-text3: #5a6077;
    --promat-jkts-mono: "JetBrains Mono", monospace;
    --promat-jkts-display: "Syne", sans-serif;
    --promat-jkts-radius: 10px;
    --promat-jkts-radius-lg: 16px;

    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 110px 32px 96px;
  }

  .promat-jkts * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .promat-jkts body {
    background: var(--promat-jkts-bg);
    color: var(--promat-jkts-text);
    font-family: var(--promat-jkts-mono);
    font-size: 14px;
    line-height: 1.7;
    min-height: 100vh;
  }

  .promat-jkts-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 64px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--promat-jkts-border);
  }
  .promat-jkts-nav-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--promat-jkts-text2);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }
  .promat-jkts-nav-back:hover {
    color: var(--promat-jkts-accent);
  }
  .promat-jkts-nav-back svg {
    width: 14px;
    height: 14px;
  }
  .promat-jkts-nav-dot {
    color: var(--promat-jkts-border2);
  }
  .promat-jkts-nav-title {
    color: var(--promat-jkts-text3);
    font-size: 12px;
  }

  .promat-jkts-hero {
    margin-bottom: 56px;
  }
  .promat-jkts-hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .promat-jkts-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    letter-spacing: 0.06em;
    font-weight: 500;
    border: 1px solid transparent;
  }
  .promat-jkts-badge-corporate {
    background: var(--promat-jkts-blue-dim);
    color: var(--promat-jkts-blue);
    border-color: rgba(96, 165, 250, 0.2);
  }
  .promat-jkts-badge-client {
    background: var(--promat-jkts-accent-dim);
    color: var(--promat-jkts-accent);
    border-color: rgba(0, 229, 160, 0.2);
  }
  .promat-jkts-badge-year {
    background: var(--promat-jkts-surface);
    color: var(--promat-jkts-text3);
    border-color: var(--promat-jkts-border);
  }

  .promat-jkts-hero-title {
    font-family: var(--promat-jkts-display);
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .promat-jkts-hero-title span {
    color: var(--promat-jkts-accent);
    position: relative;
  }

  .promat-jkts-hero-desc {
    color: var(--promat-jkts-text2);
    font-size: 14px;
    max-width: 620px;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .promat-jkts-stack-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .promat-jkts-stack-pill {
    background: var(--promat-jkts-surface);
    border: 1px solid var(--promat-jkts-border);
    color: var(--promat-jkts-text2);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    letter-spacing: 0.04em;
    transition: all 0.2s;
  }
  .promat-jkts-stack-pill:hover {
    border-color: var(--promat-jkts-accent);
    color: var(--promat-jkts-accent);
    background: var(--promat-jkts-accent-dim);
  }

  .promat-jkts-section {
    margin-bottom: 52px;
  }
  .promat-jkts-section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .promat-jkts-section-label-text {
    font-family: var(--promat-jkts-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--promat-jkts-text3);
    text-transform: uppercase;
  }
  .promat-jkts-section-label-line {
    flex: 1;
    height: 1px;
    background: var(--promat-jkts-border);
  }
  .promat-jkts-section-label-num {
    font-size: 11px;
    color: var(--promat-jkts-border2);
  }

  .promat-jkts-metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }
  .promat-jkts-metric-card {
    background: var(--promat-jkts-bg3);
    border: 1px solid var(--promat-jkts-border);
    border-radius: var(--promat-jkts-radius);
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .promat-jkts-metric-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--promat-jkts-accent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .promat-jkts-metric-card:hover {
    border-color: var(--promat-jkts-border2);
  }
  .promat-jkts-metric-card:hover::before {
    opacity: 1;
  }
  .promat-jkts-metric-amber .promat-jkts-metric-val {
    color: var(--promat-jkts-amber);
  }
  .promat-jkts-metric-amber::before {
    background: var(--promat-jkts-amber);
  }

  .promat-jkts-metric-val {
    font-family: var(--promat-jkts-display);
    font-size: 32px;
    font-weight: 800;
    color: var(--promat-jkts-accent);
    line-height: 1;
    margin-bottom: 6px;
  }
  .promat-jkts-metric-label {
    font-size: 12px;
    color: var(--promat-jkts-text2);
    margin-bottom: 3px;
  }
  .promat-jkts-metric-sub {
    font-size: 11px;
    color: var(--promat-jkts-text3);
  }

  .promat-jkts-arch-diagram {
    background: var(--promat-jkts-bg3);
    border: 1px solid var(--promat-jkts-border);
    border-radius: var(--promat-jkts-radius-lg);
    padding: 32px;
    overflow: hidden;
    position: relative;
  }
  .promat-jkts-arch-diagram-inner {
    display: flex;
    align-items: center;
    gap: 0;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 24px;
  }
  .promat-jkts-arch-node {
    background: var(--promat-jkts-surface);
    border: 1px solid var(--promat-jkts-border2);
    border-radius: var(--promat-jkts-radius);
    padding: 14px 18px;
    text-align: center;
    min-width: 130px;
    position: relative;
  }
  .promat-jkts-core {
    background: var(--promat-jkts-surface2);
    border: 1px solid rgba(0, 229, 160, 0.3);
    min-width: 200px;
  }
  .promat-jkts-output {
    border-color: rgba(96, 165, 250, 0.3);
  }
  .promat-jkts-schema-node {
    border-color: rgba(245, 158, 11, 0.3);
    background: var(--promat-jkts-amber-dim);
    min-width: 110px;
  }
  .promat-jkts-arch-node-icon {
    font-size: 18px;
    margin-bottom: 6px;
  }
  .promat-jkts-arch-node-label {
    font-family: var(--promat-jkts-display);
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 3px;
  }
  .promat-jkts-arch-node-sub {
    font-size: 10px;
    color: var(--promat-jkts-text3);
    font-family: var(--promat-jkts-mono);
  }

  .promat-jkts-arch-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 8px;
    color: var(--promat-jkts-text3);
    font-size: 11px;
    gap: 4px;
    min-width: 60px;
  }
  .promat-jkts-arch-arrow-line {
    width: 40px;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--promat-jkts-border),
      var(--promat-jkts-accent),
      var(--promat-jkts-border)
    );
    position: relative;
  }
  .promat-jkts-arch-arrow-line::after {
    content: "";
    position: absolute;
    right: -6px;
    top: -6px;
    color: var(--promat-jkts-accent);
    font-size: 10px;
  }
  .promat-jkts-arch-arrow-label {
    font-size: 9px;
    letter-spacing: 0.05em;
    color: var(--promat-jkts-text3);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .promat-jkts-core-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .promat-jkts-core-stack {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 12px;
  }
  .promat-jkts-core-step {
    background: var(--promat-jkts-bg3);
    border: 1px solid var(--promat-jkts-border);
    border-radius: 6px;
    padding: 7px 12px;
    font-size: 11px;
    color: var(--promat-jkts-text2);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .promat-jkts-core-step-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--promat-jkts-accent);
    flex-shrink: 0;
  }

  .promat-jkts-schema-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .promat-jkts-schema-line-v {
    width: 1px;
    height: 20px;
    background: rgba(245, 158, 11, 0.4);
  }
  .promat-jkts-schema-arrow-label {
    font-size: 9px;
    color: var(--promat-jkts-amber);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .promat-jkts-decision-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .promat-jkts-decision-card {
    background: var(--promat-jkts-bg3);
    border: 1px solid var(--promat-jkts-border);
    border-radius: var(--promat-jkts-radius);
    overflow: hidden;
    transition: border-color 0.25s;
  }
  .promat-jkts-decision-card:hover {
    border-color: var(--promat-jkts-border2);
  }

  .promat-jkts-decision-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 24px 0;
  }
  .promat-jkts-decision-num {
    font-family: var(--promat-jkts-display);
    font-size: 28px;
    font-weight: 800;
    color: var(--promat-jkts-border2);
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
    min-width: 32px;
  }
  .promat-jkts-decision-title {
    font-family: var(--promat-jkts-display);
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
  }
  .promat-jkts-decision-problem {
    font-size: 12px;
    color: var(--promat-jkts-text3);
    font-style: italic;
    padding: 8px 12px;
    border-left: 2px solid var(--promat-jkts-border2);
    margin: 8px 0 0;
    line-height: 1.6;
  }
  .promat-jkts-decision-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 16px 24px 20px;
  }
  @media (max-width: 540px) {
    .promat-jkts-decision-body {
      grid-template-columns: 1fr;
    }
  }
  .promat-jkts-decision-col-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .promat-jkts-decision-chosen {
    color: var(--promat-jkts-accent);
  }
  .promat-jkts-decision-tradeoff {
    color: var(--promat-jkts-amber);
  }
  .promat-jkts-decision-col-text {
    font-size: 12px;
    color: var(--promat-jkts-text2);
    line-height: 1.65;
  }

  .promat-jkts-decision-code {
    background: var(--promat-jkts-bg);
    border-top: 1px solid var(--promat-jkts-border);
    padding: 16px 24px;
    font-size: 12px;
    color: var(--promat-jkts-text2);
    overflow-x: auto;
  }
  .promat-jkts-decision-code pre {
    margin: 0;
    font-family: var(--promat-jkts-mono);
    line-height: 1.6;
  }
  .promat-jkts-token-kw {
    color: #c792ea;
  }
  .promat-jkts-token-fn {
    color: #82aaff;
  }
  .promat-jkts-token-str {
    color: #c3e88d;
  }
  .promat-jkts-token-cm {
    color: var(--promat-jkts-text3);
    font-style: italic;
  }
  .promat-jkts-token-acc {
    color: var(--promat-jkts-accent);
  }

  .promat-jkts-impact-wrapper {
    background: var(--promat-jkts-bg3);
    border: 1px solid var(--promat-jkts-border);
    border-radius: var(--promat-jkts-radius);
    overflow: hidden;
  }
  .promat-jkts-impact-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .promat-jkts-impact-table th {
    text-align: left;
    padding: 10px 16px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--promat-jkts-text3);
    border-bottom: 1px solid var(--promat-jkts-border);
    font-family: var(--promat-jkts-display);
    font-weight: 600;
  }
  .promat-jkts-impact-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--promat-jkts-border);
    color: var(--promat-jkts-text2);
  }
  .promat-jkts-impact-table tr:last-child td {
    border-bottom: none;
  }
  .promat-jkts-impact-table tr:hover td {
    background: var(--promat-jkts-surface);
  }
  .promat-jkts-before {
    color: var(--promat-jkts-red);
  }
  .promat-jkts-after {
    color: var(--promat-jkts-accent);
  }
  .promat-jkts-delta {
    color: var(--promat-jkts-accent);
    font-weight: 500;
    font-family: var(--promat-jkts-display);
    font-size: 12px;
    white-space: nowrap;
  }
  .promat-jkts-row-label {
    color: #fff;
    font-weight: 500;
  }

  .promat-jkts-stack-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .promat-jkts-stack-table td {
    padding: 10px 16px;
    border-bottom: 1px solid var(--promat-jkts-border);
  }
  .promat-jkts-stack-table tr:last-child td {
    border-bottom: none;
  }
  .promat-jkts-layer {
    color: var(--promat-jkts-text3);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .promat-jkts-tech {
    color: var(--promat-jkts-accent);
    font-family: var(--promat-jkts-mono);
  }
  .promat-jkts-stack-table tr:hover td {
    background: var(--promat-jkts-surface);
  }

  .promat-jkts-footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid var(--promat-jkts-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .promat-jkts-footer-text {
    font-size: 11px;
    color: var(--promat-jkts-text3);
  }
  .promat-jkts-footer-link {
    font-size: 11px;
    color: var(--promat-jkts-text3);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.2s;
  }
  .promat-jkts-footer-link:hover {
    color: var(--promat-jkts-accent);
  }

  @keyframes promat-jkts-fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .promat-jkts-hero {
    animation: promat-jkts-fadeUp 0.5s ease both;
  }
  .promat-jkts-section:nth-child(2) {
    animation: promat-jkts-fadeUp 0.5s 0.1s ease both;
  }
  .promat-jkts-section:nth-child(3) {
    animation: promat-jkts-fadeUp 0.5s 0.15s ease both;
  }
  .promat-jkts-section:nth-child(4) {
    animation: promat-jkts-fadeUp 0.5s 0.2s ease both;
  }
  .promat-jkts-section:nth-child(5) {
    animation: promat-jkts-fadeUp 0.5s 0.25s ease both;
  }
  .promat-jkts-section:nth-child(6) {
    animation: promat-jkts-fadeUp 0.5s 0.3s ease both;
  }

  .promat-jkts-cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--promat-jkts-accent);
    margin-left: 2px;
    vertical-align: middle;
    animation: promat-jkts-blink 1s step-end infinite;
  }
  @keyframes promat-jkts-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .promat-jkts-badge-client { background: var(--promat-jkts-accent-dim); color: var(--promat-jkts-accent); border-color: rgba(0,229,160,0.2); }
  .promat-jkts-metric-val { font-size: 22px; }
  .promat-jkts-amber .promat-jkts-metric-val { color: var(--promat-jkts-amber); }
  .promat-jkts-amber::before { background: var(--promat-jkts-amber); }
  .promat-jkts-red .promat-jkts-metric-val { color: var(--promat-jkts-red); }
  .promat-jkts-red::before { background: var(--promat-jkts-red); }
  .promat-jkts-blue .promat-jkts-metric-val { color: var(--promat-jkts-blue); }
  .promat-jkts-blue::before { background: var(--promat-jkts-blue); }
  .promat-jkts-business-line-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
  @media (max-width: 540px) { .promat-jkts-business-line-cards { grid-template-columns: 1fr; } }
  .promat-jkts-bl-card { background: var(--promat-jkts-bg2); border: 1px solid var(--promat-jkts-border); border-radius: var(--promat-jkts-radius); padding: 16px; }
  .promat-jkts-bl-card-title { font-family: var(--promat-jkts-display); font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .promat-jkts-bl-card-desc { font-size: 11px; color: var(--promat-jkts-text3); line-height: 1.6; }
  .promat-jkts-bl-card-tag { display: inline-block; margin-top: 6px; padding: 2px 8px; border-radius: 4px; font-size: 10px; background: var(--promat-jkts-accent-dim); color: var(--promat-jkts-accent); border: 1px solid rgba(0,229,160,0.2); }
  .promat-jkts-bl-card-tag.promat-jkts-amber-tag { background: var(--promat-jkts-amber-dim); color: var(--promat-jkts-amber); border-color: rgba(245,158,11,0.2); }
  .promat-jkts-cap-list { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @@media (max-width: 540px) { .promat-jkts-cap-list { grid-template-columns: 1fr; } }
  .promat-jkts-cap-item { background: var(--promat-jkts-bg3); border: 1px solid var(--promat-jkts-border); border-radius: 8px; padding: 14px 16px; display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--promat-jkts-text2); }
  .promat-jkts-cap-item:hover { border-color: var(--promat-jkts-border2); color: var(--promat-jkts-text); }
  .promat-jkts-cap-icon { width: 28px; height: 28px; border-radius: 6px; background: var(--promat-jkts-accent-dim); display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
  .promat-jkts-flow-panel { background: var(--promat-jkts-bg2); border: 1px solid var(--promat-jkts-border); border-radius: var(--promat-jkts-radius); padding: 20px; margin-top: 20px; }
