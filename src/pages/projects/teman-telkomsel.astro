          <tr>
            <td class="teman-telkomsel-row-label">Subscriber engagement</td>
            <td class="teman-telkomsel-before">Manual campaign dispatch</td>
            <td class="teman-telkomsel-after">Automated broadcasts</td>
            <td class="teman-telkomsel-delta">Full automation</td>
          </tr>
          <tr>
            <td class="teman-telkomsel-row-label">SMS scheduling</td>
            <td class="teman-telkomsel-before">Ad-hoc manual sending</td>
            <td class="teman-telkomsel-after">Cron-driven scheduler</td>
            <td class="teman-telkomsel-delta">Once/daily/weekly/monthly</td>
          </tr>
          <tr>
            <td class="teman-telkomsel-row-label">Member import</td>
            <td class="teman-telkomsel-before">Manual data entry</td>
            <td class="teman-telkomsel-after">Excel bulk upload</td>
            <td class="teman-telkomsel-delta">10× throughput</td>
          </tr>
          <tr>
            <td class="teman-telkomsel-row-label">Access control</td>
            <td class="teman-telkomsel-before">No role separation</td>
            <td class="teman-telkomsel-after">RBAC + IP binding</td>
            <td class="teman-telkomsel-delta">Full audit trail</td>
          </tr>
          <tr>
            <td class="teman-telkomsel-row-label">Scale</td>
            <td class="teman-telkomsel-before">Limited subscribers</td>
            <td class="teman-telkomsel-after">Millions of subscribers</td>
            <td class="teman-telkomsel-delta">Mission Critical</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="teman-telkomsel-section">
    <div class="teman-telkomsel-section-label">
      <span class="teman-telkomsel-section-label-text">Tech Stack</span>
      <div class="teman-telkomsel-section-label-line"></div>
      <span class="teman-telkomsel-section-label-num">05</span>
    </div>
    <div class="teman-telkomsel-impact-wrapper">
      <table class="teman-telkomsel-stack-table">
        <tbody>
          <tr>
            <td class="teman-telkomsel-layer">Language</td>
            <td class="teman-telkomsel-tech">PHP 5.x</td>
          </tr>
