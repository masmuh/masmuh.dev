      <li><a href="/#contact">Contact</a></li>
    </ul>
    <button class="mobile-nav-toggle" id="mobileThemeToggle">Toggle Theme</button>
  </div>

  <div class="teman-telkomsel">

<header class="teman-telkomsel-hero">
    <div class="teman-telkomsel-hero-meta">
      <span class="teman-telkomsel-badge teman-telkomsel-badge-corporate">Corporate</span><span class="teman-telkomsel-badge teman-telkomsel-badge-client">Telkomsel</span> 
      
      <span class="teman-telkomsel-badge teman-telkomsel-badge-year">June 2014</span>
    </div>
    <h1 class="teman-telkomsel-hero-title"><span>Teman</span> Telkomsel<span class="teman-telkomsel-cursor"></span></h1>
    <p class="teman-telkomsel-hero-desc">
      An enterprise SMS broadcast platform for Telkomsel enabling member management, community grouping, and scheduled SMS broadcasting with bulk MSISDN import. Built with CodeIgniter PHP framework on Oracle database using Modular HMVC architecture. The primary subscriber engagement system serving millions of Telkomsel customers.
    </p>
    <div class="teman-telkomsel-stack-pills">
      <span class="teman-telkomsel-stack-pill">PHP 5.x</span>
      <span class="teman-telkomsel-stack-pill">CodeIgniter 2.1.2</span>
      <span class="teman-telkomsel-stack-pill">Oracle DB (OCI8)</span>
      <span class="teman-telkomsel-stack-pill">jQuery</span>
      <span class="teman-telkomsel-stack-pill">Bootstrap 2</span>
      <span class="teman-telkomsel-stack-pill">Flexigrid</span>
      <span class="teman-telkomsel-stack-pill">PHPExcel</span>
    </div>
  </header>

  <!-- METRICS -->
  <section class="teman-telkomsel-section">
    <div class="teman-telkomsel-section-label">
      <span class="teman-telkomsel-section-label-text">Impact</span>
      <div class="teman-telkomsel-section-label-line"></div>
      <span class="teman-telkomsel-section-label-num">01</span>
    </div>
    <div class="teman-telkomsel-metrics-grid">
      <div class="teman-telkomsel-metric-card">
        <div class="teman-telkomsel-metric-val">14,000+</div>
        <div class="teman-telkomsel-metric-label">Lines of Code</div>
        <div class="teman-telkomsel-metric-sub">PHP + JS + SQL</div>
      </div>
      <div class="teman-telkomsel-metric-card">
        <div class="teman-telkomsel-metric-val">35+</div>
        <div class="teman-telkomsel-metric-label">API Endpoints</div>
        <div class="teman-telkomsel-metric-sub">5 REST + 30 AJAX</div>
      </div>
      <div class="teman-telkomsel-metric-card">
        <div class="teman-telkomsel-metric-val">36</div>
        <div class="teman-telkomsel-metric-label">Database Tables</div>
        <div class="teman-telkomsel-metric-sub">Oracle DB schema</div>
      </div>
      <div class="teman-telkomsel-metric-card teman-telkomsel-amber">
        <div class="teman-telkomsel-metric-val">10</div>
        <div class="teman-telkomsel-metric-label">Complexity Score</div>
        <div class="teman-telkomsel-metric-sub">Mission Critical</div>
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section class="teman-telkomsel-section">
    <div class="teman-telkomsel-section-label">
      <span class="teman-telkomsel-section-label-text">Architecture</span>
      <div class="teman-telkomsel-section-label-line"></div>
      <span class="teman-telkomsel-section-label-num">02</span>
    </div>
    <div class="teman-telkomsel-arch-diagram">
      <div class="teman-telkomsel-arch-diagram-inner">

        <!-- Source -->
        <div class="teman-telkomsel-arch-node teman-telkomsel-source">
          <div class="teman-telkomsel-arch-node-icon"></div>
          <div class="teman-telkomsel-arch-node-label">Web Browser</div>
          <div class="teman-telkomsel-arch-node-sub">Admin Panel</div>
        </div>

        <!-- Arrow -->
        <div class="teman-telkomsel-arch-arrow">
          <div class="teman-telkomsel-arch-arrow-line"></div>
          <div class="teman-telkomsel-arch-arrow-label">HTTP request</div>
        </div>

        <!-- Core HMVC App -->
        <div style="display:flex; flex-direction:column; align-items:center; gap:0;">
          <div class="teman-telkomsel-arch-node core" style="width:240px;">
            <div class="teman-telkomsel-arch-node-label" style="font-size:13px; margin-bottom:10px;">CodeIgniter HMVC App</div>
            <div class="teman-telkomsel-core-stack">
              <div class="teman-telkomsel-core-step">
                <div class="teman-telkomsel-core-step-dot"></div>
                Controllers · routing
              </div>
              <div class="teman-telkomsel-core-step">
                <div class="teman-telkomsel-core-step-dot"></div>
                Models · business logic
              </div>
              <div class="teman-telkomsel-core-step">
                <div class="teman-telkomsel-core-step-dot" style="background:var(--blue)"></div>
                Views · Bootstrap UI
              </div>
            </div>
          </div>
          <!-- Oracle connector going down -->
          <div class="teman-telkomsel-schema-connector" style="margin-top:0;">
            <div class="teman-telkomsel-schema-line-v"></div>
            <div class="teman-telkomsel-schema-arrow-label">OCI8 persist</div>
            <div class="teman-telkomsel-schema-line-v"></div>
            <div class="teman-telkomsel-arch-node teman-telkomsel-schema-node">
              <div class="teman-telkomsel-arch-node-label" style="font-size:11px; color: #f59e0b;">Oracle DB</div>
              <div class="teman-telkomsel-arch-node-sub">36 tables</div>
            </div>
          </div>
        </div>

        <!-- Arrow -->
        <div class="teman-telkomsel-arch-arrow">
          <div class="teman-telkomsel-arch-arrow-line"></div>
          <div class="teman-telkomsel-arch-arrow-label">SMS API</div>
        </div>

        <!-- Output -->
        <div class="teman-telkomsel-arch-node teman-telkomsel-output">
          <div class="teman-telkomsel-arch-node-icon"></div>
          <div class="teman-telkomsel-arch-node-label">SMS Gateway</div>
          <div class="teman-telkomsel-arch-node-sub">Telkomsel infra</div>
        </div>

      </div>
    </div>
  </section>

  <!-- DECISIONS -->
  <section class="teman-telkomsel-section">
    <div class="teman-telkomsel-section-label">
      <span class="teman-telkomsel-section-label-text">Decision Log</span>
      <div class="teman-telkomsel-section-label-line"></div>
      <span class="teman-telkomsel-section-label-num">03</span>
    </div>
    <div class="teman-telkomsel-decision-list">

      <!-- Decision 1 -->
      <div class="teman-telkomsel-decision-card">
        <div class="teman-telkomsel-decision-header">
          <div class="teman-telkomsel-decision-num">01</div>
          <div>
            <div class="teman-telkomsel-decision-title">Modular HMVC — Hierarchical Separation of Concerns</div>
            <div class="teman-telkomsel-decision-problem">
              Monolithic MVC controllers became unmanageable as the platform grew to support multiple community groups, scheduling modes, and role-based access across dozens of modules.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-body">
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-chosen">▸ Chosen</div>
            <div class="teman-telkomsel-decision-col-text">
              Modular HMVC (Hierarchical Model-View-Controller) pattern using CodeIgniter with third-party HMVC extension. Each domain (member management, scheduling, import, reporting) became an isolated module with its own controllers, models, and views.
            </div>
          </div>
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-tradeoff">▸ Trade-off</div>
            <div class="teman-telkomsel-decision-col-text">
              Increased initial architecture complexity and module wiring overhead. Accepted because it enabled parallel development, clear ownership boundaries, and independent deployment of modules without touching the core.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-code">
<pre><span class="teman-telkomsel-token-cm">//  Before: flat MVC — everything in one controller</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Sms extends CI_Controller &#123;</span>
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">send</span>() &#123; &#125;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">schedule</span>() &#123; &#125;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">import_member</span>() &#123; &#125;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">group_management</span>() &#123; &#125;
<span class="teman-telkomsel-token-kw">&#125;</span>

<span class="teman-telkomsel-token-cm">//  After: modular HMVC — each domain isolated</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Sms_Broadcast extends MX_Controller</span> &#123;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">send</span>() &#123; &#125;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">schedule</span>() &#123; &#125;
<span class="teman-telkomsel-token-kw">&#125;</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Member_Import extends MX_Controller</span> &#123;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">upload_excel</span>() &#123; &#125;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">validate</span>() &#123; &#125;
<span class="teman-telkomsel-token-kw">&#125;</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Community extends MX_Controller</span> &#123;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">manage_groups</span>() &#123; &#125;
<span class="teman-telkomsel-token-kw">&#125;</span></pre>
        </div>
      </div>

      <!-- Decision 2 -->
      <div class="teman-telkomsel-decision-card">
        <div class="teman-telkomsel-decision-header">
          <div class="teman-telkomsel-decision-num">02</div>
          <div>
            <div class="teman-telkomsel-decision-title">SMS Scheduling — Cron-Driven Broadcast Engine</div>
            <div class="teman-telkomsel-decision-problem">
              Manual SMS dispatching was error-prone and unscalable. Operators needed to schedule campaigns for specific dates and repeat intervals across millions of subscribers without human intervention.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-body">
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-chosen">▸ Chosen</div>
            <div class="teman-telkomsel-decision-col-text">
              Database-driven scheduler with server cron triggering. Scheduling support for one-time, daily, weekly, and monthly recurrence. The cron job polls pending broadcasts, batches subscribers, and dispatches via SMS gateway API with retry logic.
            </div>
          </div>
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-tradeoff">▸ Trade-off</div>
            <div class="teman-telkomsel-decision-col-text">
              Polling-based scheduling introduces slight delay between scheduled time and actual dispatch. Accepted: cron granularity at 1-minute intervals was sufficient for Telkomsel's operational requirements without real-time constraints.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-code">
<pre><span class="teman-telkomsel-token-cm">// Scheduler cron handler — polls pending broadcasts</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Scheduler extends MX_Controller</span> &#123;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">process_queue</span>() &#123;
        <span class="teman-telkomsel-token-kw">$pending</span> = <span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">scheduler_model</span>
            -><span class="teman-telkomsel-token-fn">getDueBroadcasts</span>();

        <span class="teman-telkomsel-token-kw">foreach</span> (<span class="teman-telkomsel-token-acc">$pending</span> <span class="teman-telkomsel-token-kw">as</span> <span class="teman-telkomsel-token-acc">$broadcast</span>) &#123;
            <span class="teman-telkomsel-token-acc">$batches</span> = <span class="teman-telkomsel-token-fn">array_chunk</span>(
                <span class="teman-telkomsel-token-acc">$broadcast</span>->recipients, <span class="teman-telkomsel-token-acc">1000</span>
            );
            <span class="teman-telkomsel-token-kw">foreach</span> (<span class="teman-telkomsel-token-acc">$batches</span> <span class="teman-telkomsel-token-kw">as</span> <span class="teman-telkomsel-token-acc">$batch</span>) &#123;
                <span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">gateway</span>-><span class="teman-telkomsel-token-fn">send</span>(<span class="teman-telkomsel-token-acc">$batch</span>);
            &#125;
        &#125;
    &#125;
&#125;</pre>
        </div>
      </div>

      <!-- Decision 3 -->
      <div class="teman-telkomsel-decision-card">
        <div class="teman-telkomsel-decision-header">
          <div class="teman-telkomsel-decision-num">03</div>
          <div>
            <div class="teman-telkomsel-decision-title">Bulk MSISDN Import — Excel-Based Validation Pipeline</div>
            <div class="teman-telkomsel-decision-problem">
              Operators managed subscriber lists in Excel spreadsheets. Manual entry of MSISDN numbers into the web interface was slow, error-prone, and lacked validation for phone number formatting and duplicates.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-body">
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-chosen">▸ Chosen</div>
            <div class="teman-telkomsel-decision-col-text">
              PHPExcel-powered bulk import pipeline. Operators upload .xls files containing MSISDN lists. The system validates formatting, strips invalid numbers, checks duplicates against existing members, and inserts validated records in a single transaction.
            </div>
          </div>
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-tradeoff">▸ Trade-off</div>
            <div class="teman-telkomsel-decision-col-text">
              Large Excel files consume significant PHP memory during parsing. Mitigated with row-by-row streaming and a max-rows cap per import session. Very large datasets require splitting across multiple uploads.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-code">
<pre><span class="teman-telkomsel-token-cm">// Bulk MSISDN import with validation pipeline</span>
<span class="teman-telkomsel-token-kw">class</span> <span class="teman-telkomsel-token-fn">Member_Import extends MX_Controller</span> &#123;
    <span class="teman-telkomsel-token-kw">function</span> <span class="teman-telkomsel-token-fn">process_upload</span>() &#123;
        <span class="teman-telkomsel-token-acc">$excel</span> = <span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">phpexcel</span>-><span class="teman-telkomsel-token-fn">load</span>(<span class="teman-telkomsel-token-acc">$uploaded_file</span>);
        <span class="teman-telkomsel-token-acc">$valid</span> = [];
        <span class="teman-telkomsel-token-acc">$errors</span> = [];

        <span class="teman-telkomsel-token-kw">foreach</span> (<span class="teman-telkomsel-token-acc">$excel</span>-><span class="teman-telkomsel-token-fn">getRowIterator</span>() <span class="teman-telkomsel-token-kw">as</span> <span class="teman-telkomsel-token-acc">$row</span>) &#123;
            <span class="teman-telkomsel-token-acc">$msisdn</span> = <span class="teman-telkomsel-token-fn">trim</span>(<span class="teman-telkomsel-token-acc">$row</span>[<span class="teman-telkomsel-token-str">'msisdn'</span>]);
            <span class="teman-telkomsel-token-kw">if</span> (<span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">validation</span>-><span class="teman-telkomsel-token-fn">isValidMsisdn</span>(<span class="teman-telkomsel-token-acc">$msisdn</span>)) &#123;
                <span class="teman-telkomsel-token-acc">$valid</span>[] = <span class="teman-telkomsel-token-acc">$msisdn</span>;
            &#125; <span class="teman-telkomsel-token-kw">else</span> &#123;
                <span class="teman-telkomsel-token-acc">$errors</span>[] = <span class="teman-telkomsel-token-acc">$row</span>[<span class="teman-telkomsel-token-str">'row'</span>] . <span class="teman-telkomsel-token-str">': invalid'</span>;
            &#125;
        &#125;

        <span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">member_model</span>-><span class="teman-telkomsel-token-fn">batch_insert</span>(<span class="teman-telkomsel-token-acc">$valid</span>);
        <span class="teman-telkomsel-token-acc">$this</span>-><span class="teman-telkomsel-token-fn">session</span>-><span class="teman-telkomsel-token-fn">set_flashdata</span>(<span class="teman-telkomsel-token-str">'import_result'</span>, [
            <span class="teman-telkomsel-token-str">'imported'</span> => <span class="teman-telkomsel-token-fn">count</span>(<span class="teman-telkomsel-token-acc">$valid</span>),
            <span class="teman-telkomsel-token-str">'rejected'</span> => <span class="teman-telkomsel-token-acc">$errors</span>
        ]);
    &#125;
&#125;</pre>
        </div>
      </div>

      <!-- Decision 4 -->
      <div class="teman-telkomsel-decision-card">
        <div class="teman-telkomsel-decision-header">
          <div class="teman-telkomsel-decision-num">04</div>
          <div>
            <div class="teman-telkomsel-decision-title">Role-Based Access Control — Menu-Level Privileges</div>
            <div class="teman-telkomsel-decision-problem">
              The platform served multiple Telkomsel teams with different operational responsibilities. A flat permission model posed security risks and made audit compliance difficult.
            </div>
          </div>
        </div>
        <div class="teman-telkomsel-decision-body">
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-chosen">▸ Chosen</div>
            <div class="teman-telkomsel-decision-col-text">
              Hierarchical RBAC with menu-level privilege granularity. Each user role maps to a set of visible menu items and actions. Combined with session-based authentication and IP binding for additional security in Telkomsel's internal network.
            </div>
          </div>
          <div>
            <div class="teman-telkomsel-decision-col-label teman-telkomsel-tradeoff">▸ Trade-off</div>
            <div class="teman-telkomsel-decision-col-text">
              Menu-level RBAC requires explicit permission definitions for each new feature. Accepted: the audit trail and security compliance requirements from Telkomsel's IT security team made this granularity necessary rather than optional.
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- BUSINESS IMPACT -->
  <section class="teman-telkomsel-section">
    <div class="teman-telkomsel-section-label">
      <span class="teman-telkomsel-section-label-text">Business Impact</span>
      <div class="teman-telkomsel-section-label-line"></div>
      <span class="teman-telkomsel-section-label-num">04</span>
    </div>
    <div class="teman-telkomsel-impact-wrapper">
