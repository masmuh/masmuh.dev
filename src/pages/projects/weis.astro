        </tr>
        <tr>
          <td class="weis-layer">Runtime</td>
          <td class="weis-tech">.NET Framework 4.6.2, IIS / Docker container</td>
        </tr>
        <tr>
          <td class="weis-layer">CI/CD</td>
          <td class="weis-tech">GitLab CI/CD, Docker, Windows container deployment</td>
        </tr>
        <tr>
          <td class="weis-layer">IDE &amp; Tooling</td>
          <td class="weis-tech">Visual Studio 2017/2019, ReSharper, Git, MongoDB Compass, Oracle SQL Developer</td>
        </tr>
      </table>
    </div>
  </section>

