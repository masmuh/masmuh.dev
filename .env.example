# Cloudflare API credentials for Security Dashboard
# Get API Token: Cloudflare Dashboard → My Profile → API Tokens
# Required permissions: Analytics:Read, Firewall:Read, Zone:Read
CF_API_TOKEN=your_cloudflare_api_token_here

# Zone ID for the monitored domain
# Get Zone ID: Cloudflare Dashboard → masmuh.web.id → Overview → API Zone ID
CF_ZONE_ID=your_zone_id_here

# ─── Google Analytics 4 ─────────────────────────────
# Cara 1: Service Account JSON (langsung satu variable)
# Buat service account di Google Cloud Console → IAM & Admin → Service Accounts
# Enable: Analytics Data API (https://console.cloud.google.com/apis/library/analyticsdata.googleapis.com)
# Add service account email ke GA4 property sebagai Viewer
GA_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Cara 2: Variable terpisah (alternatif)
# GA_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# GA4 Property ID (angka, bukan UA ID)
# Dapat dari: Google Analytics → Admin → Property Settings → Property ID
GA_PROPERTY_ID=your_ga4_property_id_here
